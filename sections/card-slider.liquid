{% schema %}
{
  "name": "Cards Slider",
  "settings": [
    {
      "type": "select",
      "id": "card_height",
      "label": "Card Height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "arrows_position",
      "label": "Arrows Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-right",
          "label": "Top Right" 
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        }
      ],
      "default": "bottom-right"
    },
    {
      "type": "color",
      "id": "arrows_background",
      "label": "Arrows Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrows_color",
      "label": "Arrows Icon Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "slider_speed",
      "min": 100,
      "max": 5000,
      "step": 100,
      "unit": "ms",
      "label": "Slider Transition Speed",
      "default": 300
    },
    {
        "type": "range",
        "id": "margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Margin Top",
        "unit": "px",
        "default": 20
    },
    {
        "type": "range",
        "id": "margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Margin Bottom",
        "unit": "px",
        "default": 20
    },
    {
        "type": "range",
        "id": "card_border_radius",
        "min": 0,
        "max": 50,
        "step": 1,
        "label": "Card Border Radius",
        "unit": "px",
        "default": 15
    },
    {
        "type": "range",
        "id": "space_between_cards",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Space Between Cards",
        "unit": "px",
        "default": 30
    },
    {
      "type": "header",
      "content": "Progress Bar"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "label": "Show Progress Bar",
      "default": true
    },
    {
      "type": "color",
      "id": "progress_bar_color",
      "label": "Progress Bar Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image (optional)",
          "info": "If not selected, product image will be used"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Leave blank to use product title"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "price_text",
          "label": "Price Text",
          "info": "Example: 'From €300'"
        },
        {
          "type": "color",
          "id": "price_color",
          "label": "Price Color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button Color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cards Slider",
      "category": "Custom Content",
      "blocks": [
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        }
      ]
    }
  ]
}
{% endschema %}

{% if section.settings.arrows_position == 'bottom-right' %}
  {%  assign row_order = 'not-reverse' %}
{% elsif section.settings.arrows_position == 'bottom-left' %}
  {%  assign row_order = 'not-reverse' %}
{% elsif section.settings.arrows_position == 'top-left' %}
    {%  assign row_order = 'reverse' %}
{% elsif section.settings.arrows_position == 'top-right' %}
    {%  assign row_order = 'reverse' %}
{% endif %}

<div class="cards-slider-section"  data-arrows-position="{{ section.settings.arrows_position }}" style="margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;">
    {% if section.blocks.size > 0 %}
    <div class="cards-slider-container cards-order--{{ row_order }}">
        <div class="cards-slider cards-slider--{{ section.settings.card_height }} swiper-container">
            <div class="swiper-wrapper">
            {% for block in section.blocks %}
                {% if block.type == 'product_card' and block.settings.product != blank %}
                {% assign product = block.settings.product %}
                {% assign background_image = block.settings.background_image | default: product.featured_image %}
                {% assign card_title = block.settings.title | default: product.title %}
                {% assign button_text = block.settings.button_text | default: 'Shop Now' %}

                <div class="card-slide swiper-slide" {{ block.shopify_attributes }}>
                    <a href="{{ product.url }}" class="card-slide__link">
                    <div class="card-slide__content">
                        <div class="card-slide__background-wrapper">
                        <div class="card-slide__background">
                            {% if background_image != blank %}
                            {% assign img_url = background_image | img_url: '1200x' %}
                            <img src="{{ img_url }}" alt="{{ card_title }}" loading="lazy">
                            {% else %}
                            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {% endif %}
                        </div>
                        <div class="card-slide__overlay"></div>
                        </div>
                        
                        <div class="card-slide__text-container">
                        <h3 class="card-slide__title" style="color: {{ block.settings.title_color }}">{{ card_title }}</h3>
                        
                        {% if block.settings.price_text != blank %}
                            <div class="card-slide__price" style="color: {{ block.settings.price_color }}">
                            {{ block.settings.price_text }}
                            </div>
                        {% endif %}
                        
                        <div class="card-slide__button-wrapper">
                            <span class="card-slide__button" 
                            style="background-color: {{ block.settings.button_color }}; color: {{ block.settings.button_text_color }}">
                            {{ button_text }}
                            </span>
                        </div>
                        </div>
                    </div>
                    </a>
                </div>
                {% endif %}
            {% endfor %}
            </div>
        </div>

        {% if section.settings.show_progress_bar %}
            <div class="slider-progress">
                <span class="slider-progress-bar" style="background-color: {{ section.settings.progress_bar_color }}"></span>
            </div>
        {% endif %}
      
        <div class="navigation-container navigation-container--{{ section.settings.arrows_position }}">
            <div class="swiper-button-prev" 
                style="background-color: {{ section.settings.arrows_background }}; color: {{ section.settings.arrows_color }}">
            </div>
            <div class="swiper-button-next" 
                style="background-color: {{ section.settings.arrows_background }}; color: {{ section.settings.arrows_color }}">
            </div>
        </div>
    </div>
    {% else %}
        <div class="placeholder-container" style="padding: {{ section.settings.padding }}px;">
            <div class="placeholder-message">Add product cards to display your slider</div>
        </div>
    {% endif %}
</div>

{% stylesheet %}
  
.cards-slider-section {
    width: 100%;
    position: relative;
    margin: 0 auto;
    padding: 0 40px;
}

.cards-slider-container {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.cards-order--reverse {
    flex-direction: column-reverse;
    .slider-progress{
        margin-top: 20px;
    }
}

.cards-order--not-reverse {
    flex-direction: column;
    .slider-progress {
        margin-bottom: 20px;
    }
}

.cards-slider {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 24px; /* Add space for progress bar */
    margin-top: 24px; /* Add space for progress bar */
}

.cards-slider--small {
    height: 500px;
}

.cards-slider--medium {
    height: 600px;
}
  
.cards-slider--large {
    height: 700px;
}
  
.card-slide {
    height: 100%;
    width: 100%;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
}
  
  .card-slide__link {
    display: block;
    height: 100%;
    width: 100%;
    text-decoration: none;
}
  
.card-slide__content {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
}
  
.card-slide__background-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
}
  
.card-slide__background {
    height: 100%;
    width: 100%;
}
  
.card-slide__background img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center;
}
  
.card-slide__overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.5) 100%);
    z-index: 2;
}
  
.card-slide__text-container {
    padding: 2rem;
    position: relative;
    z-index: 3;
}
  
.card-slide__title {
    font-size: 1.8rem;
    margin: 0 0 0.5rem;
    font-weight: 600;
}
  
.card-slide__price {
    font-size: 1.2rem;
    margin-bottom: 1rem;
}
  
.card-slide__button-wrapper {
    margin-top: 1rem;
}
  
.card-slide__button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: 500;
    transition: opacity 0.3s ease;
}
  
.card-slide__button:hover {
    opacity: 0.9;
}
  
/* Navigation Styles */
.navigation-container {
    position: relative;
    width: 100%;
    height: 40px;
    gap: 10px;
    display: flex;
    flex-direction: row;
}
  
.swiper-button-prev,
.swiper-button-next {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 5px rgba(0,0,0,0.15);
    transition: opacity 0.3s ease;
    cursor: pointer;
    position: initial;
    margin-top: 0; /* Reset margin */
}
  
.swiper-button-prev:hover,
.swiper-button-next:hover {
    opacity: 0.9;
}
  
.swiper-button-prev:after,
.swiper-button-next:after {
    font-size: 18px;
}
  
/* Arrow Positions */  
.navigation-container--top-left {
    justify-content: left;
}
  
.navigation-container--top-right {
    justify-content: right;
}
  
.navigation-container--bottom-left {
    justify-content: left;
}
  
.navigation-container--bottom-right {
    justify-content: right;
}
  
/* Progress Bar */
.slider-progress {
    position: relative;
    width: 100%;
    height: 2px;
    background-color: rgba(0, 0, 0, 0.1);
    z-index: 10;
    border-radius: 2px;
    overflow: hidden;
  }
  
  .slider-progress-bar {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0%; /* Will be controlled by JS */
      transition: width 0.3s ease;
    }
    
    .placeholder-container {
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f8f8;
        border: 2px dashed #ddd;
    }
    
    .placeholder-message {
        font-size: 1.2rem;
        color: #888;
    }
    
    /* Responsive adjustments */
    @media screen and (max-width: 1024px) {
        .cards-slider-section {
            padding: 0 40px;
        }
        
        .cards-slider--small {
            height: 350px;
        }
        
        .cards-slider--medium {
            height: 450px;
        }
        
        .cards-slider--large {
            height: 500px;
        }
        
        .card-slide__title {
            font-size: 1.5rem;
        }
        
        .card-slide__price {
            font-size: 1rem;
        }
        
        .card-slide__text-container {
            padding: 1.5rem;
        }
        
        .swiper-button-prev,
        .swiper-button-next {
            width: 35px;
            height: 35px;
        }

        .navigation-container {
            height: 35px;
        }
        
        .swiper-button-prev:after,
        .swiper-button-next:after {
            font-size: 16px;
        }
        
        .navigation-container--top-left,
        .navigation-container--top-right,
        .navigation-container--bottom-left,
        .navigation-container--bottom-right {
            gap: 8px;
        }
    }
    
  @media screen and (max-width: 480px) {
      .cards-slider-section {
          padding: 0 35px;
        }
        
        .cards-slider--small {
            height: 300px;
        }
        
        .cards-slider--medium {
            height: 350px;
        }
        
        .cards-slider--large {
            height: 400px;
        }
        
        .card-slide__title {
            font-size: 1.2rem;
        }
        
        .card-slide__button {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
        }
        
        .card-slide__text-container {
            padding: 1rem;
        }
        
        .swiper-button-prev,
        .swiper-button-next {
            width: 30px;
            height: 30px;
        }

        .navigation-container {
            height: 30px;
        }
        
        .swiper-button-prev:after,
        .swiper-button-next:after {
            font-size: 14px;
        }
    }
{% endstylesheet %}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var cardsSlider = new Swiper('.cards-slider', {
            slidesPerView: 1,
            spaceBetween: {{ section.settings.space_between_cards }},
            loop: false, // No infinite loop as requested
            speed: {{ section.settings.slider_speed }}, //ms 
            pagination: {
                el: '.swiper-pagination',
                clickable: true
            },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: 3,
        },
        1440: {
          slidesPerView: 4,
        }
      }
    });
    
    {% if section.settings.show_progress_bar %}
      // Fixed progress bar functionality
      var progressBar = document.querySelector('.slider-progress-bar');
      
      function updateProgressBar() {
        if (!progressBar) return;
        
        // Calculate total slides and current position and current slidesPerView
        var totalSlides = cardsSlider.slides.length;
        var activeIndex = cardsSlider.activeIndex;
        var slidesPerView = cardsSlider.params.slidesPerView;
        console.log('Slides Per View:', slidesPerView);
        console.log('Active Index:', activeIndex);
        console.log('Total Slides:', totalSlides);
        // When loop is false, use actual index
        var progress = (100 / (totalSlides - slidesPerView))*activeIndex;
        
        // Ensure progress is between 0 and 100%
        progress = Math.max(0, Math.min(100, progress));
        // Update width instead of transform for a filling effect
        progressBar.style.width = progress + '%';
      }
      
      // Initialize progress bar
      updateProgressBar();
      
      // Update progress bar when slide changes
      cardsSlider.on('slideChange', function() {
        updateProgressBar();
      });
    {% endif %}
  });
</script>