{% schema %}
{
  "name": "Cards Slider",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Section Title",
      "info": "This title will be displayed above the slider."
    },
    {
      "type": "color",
      "id": "section_title_color",
      "label": "Section Title Color",
      "default": "#000000",
      "info": "Choose a color for the section title."
    },
    {
      "type": "select",
      "id": "card_height",
      "label": "Card Height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "arrows_position",
      "label": "Arrows Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-right",
          "label": "Top Right" 
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        }
      ],
      "default": "bottom-right"
    },
    {
      "type": "color",
      "id": "arrows_background",
      "label": "Arrows Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrows_color",
      "label": "Arrows Icon Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "slider_speed",
      "min": 100,
      "max": 5000,
      "step": 100,
      "unit": "ms",
      "label": "Slider Transition Speed",
      "default": 300
    },
    {
        "type": "range",
        "id": "margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Margin Top",
        "unit": "px",
        "default": 20
    },
    {
        "type": "range",
        "id": "margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Margin Bottom",
        "unit": "px",
        "default": 20
    },
    {
        "type": "range",
        "id": "card_border_radius",
        "min": 0,
        "max": 50,
        "step": 1,
        "label": "Card Border Radius",
        "unit": "px",
        "default": 15
    },
    {
        "type": "range",
        "id": "space_between_cards",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Space Between Cards",
        "unit": "px",
        "default": 30
    },
    {
      "type": "header",
      "content": "Progress Bar"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "label": "Show Progress Bar",
      "default": true
    },
    {
      "type": "color",
      "id": "progress_bar_color",
      "label": "Progress Bar Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image (optional)",
          "info": "If not selected, product image will be used"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Leave blank to use product title"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "price_text",
          "label": "Price Text",
          "info": "Example: 'From €300'"
        },
        {
          "type": "color",
          "id": "price_color",
          "label": "Price Color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button Color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "info_card",
      "name": "Info Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image",
