<script>
  document.addEventListener('DOMContentLoaded', function() {
      var cardsSlider = new Swiper('.cards-slider', {
          slidesPerView: 1,
          spaceBetween: {{ section.settings.space_between_cards }},
          loop: false, // No infinite loop as requested
          speed: {{ section.settings.slider_speed }}, //ms 
          pagination: {
              el: '.swiper-pagination',
              clickable: true
          },
          navigation: {
              nextEl: '.swiper-button-next',
              prevEl: '.swiper-button-prev',
          },
          breakpoints: {
              640: {
                  slidesPerView: 2,
              },
              1024: {
                  slidesPerView: 3,
              },
              1440: {
                  slidesPerView: 4,
              }
          }
      });
      
      {% if section.settings.show_progress_bar %}
          // Progress bar functionality
          var progressBar = document.querySelector('.slider-progress-bar');
          
          function updateProgressBar() {
              if (!progressBar) return;
              
              // Calculate total slides and current position and current slidesPerView
              var totalSlides = cardsSlider.slides.length;
              var activeIndex = cardsSlider.activeIndex;
              var slidesPerView = cardsSlider.params.slidesPerView;
              
              // When loop is false, use actual index
              var progress = (100 / (totalSlides - slidesPerView))*activeIndex;
              
              // Ensure progress is between 0 and 100%
              progress = Math.max(0, Math.min(100, progress));
              // Update width instead of transform for a filling effect
              progressBar.style.width = progress + '%';
          }
          
          // Initialize progress bar
          updateProgressBar();
          
          // Update progress bar when slide changes
          cardsSlider.on('slideChange', function() {
              updateProgressBar();
          });
      {% endif %}
      
      // Card flip functionality
      const flipButtons = document.querySelectorAll('.card-flip-button');
      
      flipButtons.forEach(button => {
          button.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopPropagation();
              
              // Find the parent card
              const card = this.closest('.info-card');
              
              // Toggle the flip class
              card.classList.toggle('flip');
          });
      });
      
      // Stop Swiper when interacting with flip cards
      const infoCards = document.querySelectorAll('.info-card');
      
      infoCards.forEach(card => {
          card.addEventListener('touchstart', function(e) {
              if (card.classList.contains('flip')) {
                  e.stopPropagation();
              }
          }, {passive: true});
          
          card.addEventListener('touchmove', function(e) {
              if (card.classList.contains('flip')) {
                  e.stopPropagation();
              }
          }, {passive: true});
      });
  });
</script>