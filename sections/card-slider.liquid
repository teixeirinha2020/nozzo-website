{% if section.settings.arrows_position == 'bottom-right' %}
  {%  assign row_order = 'not-reverse' %}
{% elsif section.settings.arrows_position == 'bottom-left' %}
  {%  assign row_order = 'not-reverse' %}
{% elsif section.settings.arrows_position == 'top-left' %}
    {%  assign row_order = 'reverse' %}
{% elsif section.settings.arrows_position == 'top-right' %}
    {%  assign row_order = 'reverse' %}
{% endif %}

<div class="cards-slider-section"  data-arrows-position="{{ section.settings.arrows_position }}" style="margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;">
    {% if section.blocks.size > 0 %}
    <div class="cards-slider-container cards-order--{{ row_order }}">
      {% if row_order == 'not-reverse' %}
      <div class="cards-title"><h1 style="color: {{ section.settings.section_title_color }}; margin: 0;">{{ section.settings.section_title }}</h1></div>
      {% endif %}
      <div class="cards-slider-wrapper">
        <div class="cards-slider cards-slider--{{ section.settings.card_height }} swiper-container">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'product_card' and block.settings.product != blank %}
                  {% assign product = block.settings.product %}
                  {% assign background_image = block.settings.background_image | default: product.featured_image %}
                  {% assign card_title = block.settings.title | default: product.title %}
                  {% assign button_text = block.settings.button_text | default: 'Shop Now' %}
  
                  <div class="card-slide swiper-slide" {{ block.shopify_attributes }}>  
                      <a href="{{ product.url }}" class="card-slide__link">
                      <div class="card-slide__content">
                          <div class="card-slide__background-wrapper">
                          <div class="card-slide__background">
                              {% if background_image != blank %}
                              {% assign img_url = background_image | img_url: '1200x' %}
                              <img src="{{ img_url }}" alt="{{ card_title }}" loading="lazy">
                              {% else %}
                              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                              {% endif %}
                          </div>
                          <div class="card-slide__overlay"></div>
                          </div>
                          
                          <div class="card-slide__text-container">
                          <h1 class="card-slide__title" style="color: {{ block.settings.title_color }}">{{ card_title }}</h1>
                          
                          {% if block.settings.price_text != blank %}
                              <div class="card-slide__price" style="color: {{ block.settings.price_color }}">
                              {{ block.settings.price_text }}
                              </div>
                          {% endif %}
                          
                          <div class="card-slide__button-wrapper">
                              <span class="card-slide__button" 
                              style="background-color: {{ block.settings.button_color }}; color: {{ block.settings.button_text_color }}">
                              {{ button_text }}
                              </span>
                          </div>
                          </div>
                      </div>
                      </a>
                  </div>
                {% elsif block.type == 'info_card' %}
                  {% assign background_image = block.settings.background_image %}
                  {% assign card_title = block.settings.title | default: 'Info Card' %}
                  {% assign card_icon = block.settings.icon %}
                  {% assign card_icon_color = block.settings.icon_color %}
                  <div class="card-slide swiper-slide info-card" {{ block.shopify_attributes }}>
                    <div class="card-flip-container">
                      <!-- Front side of the card -->
                      <div class="card-side card-front">
                        <div class="card-slide__content">
                          <div class="card-slide__background-wrapper">
                            <div class="card-slide__background" style="border-radius: {{ section.settings.card_border_radius }}px;">
                              {% if background_image != blank %}
                                {% assign img_url = background_image | img_url: '1200x' %}
                                <img src="{{ img_url }}" alt="{{ card_title }}" loading="lazy">
                              {% else %}
                                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                              {% endif %}
                            </div>
                            <div class="card-slide__overlay" style="display: initial;"></div>
                          </div>
                          
                          <!-- Tag with icon in top left -->
                          <div class="card-tag" style="color: {{ block.settings.tag_text_color }}; background-color: {{ block.settings.tag_background_color | append: '4D'}}">
                            <span class="icon" style="fill: {{ card_icon_color }}">{% render 'icon-accordion', icon: card_icon %}</span>
                            <span class="tag-text">{{ block.settings.tag_text }}</span>
                          </div>
                          
                          <!-- Flip button in top right -->
                          <button class="card-flip-button" style="color: {{ block.settings.flip_button_color  }}; background-color: {{ block.settings.flip_button_background | append: '4D'}}">
                            <span class="plus-icon">{% render 'icon-plus' %}</span>
                          </button>
                          
                          <!-- Title at the bottom -->
                          <div class="card-slide__text-container">
                            <h1 class="card-slide__main-title" style="color: {{ block.settings.title_color }}">
                              {{ block.settings.title }}
                            </h1>
                            <h1 class="card-slide__styled-title" style="color: {{ block.settings.styled_title_color }}">
                              {{ block.settings.styled_title }}
                            </h1>
                          </div>
                        </div>
                      </div>
                      
                      <!-- Back side of the card -->
                      <div class="card-side card-back">
                        <div class="card-slide__content">
                          <div class="card-slide__background-wrapper">
                            <div class="card-slide__background">
                              {% if background_image != blank %}
                                {% assign img_url = background_image | img_url: '1200x' %}
                                <img src="{{ img_url }}" alt="{{ card_title }}" loading="lazy">
                              {% else %}
                                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                              {% endif %}
                            </div>
                            <div class="card-slide__overlay" style="background-color: {{ block.settings.back_overlay_color  | append: '4D'}}; display: inline; backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);"></div>
                          </div>
                          
                          <!-- Close button in top right -->
                          <button class="card-flip-button" style="color: {{ block.settings.flip_button_color }}; background-color: {{ block.settings.flip_button_background }}">
                            <span class="close-icon">{% render 'icon-close' %}</span>
                          </button>
                          
                          <!-- Description content -->
                          <div class="card-slide__text-container">
                            <div class="card-slide__description" style="color: {{ block.settings.description_color }}">
                              {{ block.settings.description }}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
        </div>
        {% if section.settings.show_progress_bar %}
          <div class="slider-progress">
              <span class="slider-progress-bar" style="background-color: {{ section.settings.progress_bar_color }}"></span>
          </div>
        {% endif %}
      </div>
      <div class="navigation-text-container navigation-text-container--{{ section.settings.arrows_position }}" {% if row_order == 'not-reverse' %}class="text-visible"{% endif %}>
        {% if row_order == 'reverse' %}
        <div class="cards-title"><h1 style="color: {{ section.settings.section_title_color }}; margin: 0;">{{ section.settings.section_title }}</h1></div>
        {% endif %}
        <div class="navigation-container">
            <div class="swiper-button-prev" 
                style="background-color: {{ section.settings.arrows_background }}; color: {{ section.settings.arrows_color }}">
            </div>
            <div class="swiper-button-next" 
                style="background-color: {{ section.settings.arrows_background }}; color: {{ section.settings.arrows_color }}">
            </div>
        </div>
      </div>
    </div>
    {% else %}
        <div class="placeholder-container" style="padding: {{ section.settings.padding }}px;">
            <div class="placeholder-message">Add product cards or info cards to display your slider</div>
        </div>
    {% endif %}
</div>
<style>
  .card-slide {
    border-radius: {{ section.settings.card_border_radius }}px;
  }
</style>

<style>
  
.cards-slider-section {
    width: 100%;
    position: relative;
    margin: 0 auto;
    padding: 0 60px;
}

.cards-slider-container {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
}

.cards-slider-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: center;
}

.cards-title {
  display: flex;
  justify-content: left;
}

.cards-order--reverse {
    flex-direction: column-reverse;
}

.cards-order--not-reverse {
    flex-direction: column;
    .slider-progress {
      margin-bottom: 15px;
    }
}

.cards-slider {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 20px; /* Add space for progress bar */
    margin-top: 14px; /* Add space for progress bar */
}

.cards-slider--small {
    height: 500px;
}

.cards-slider--medium {
    height: 600px;
}
  
.cards-slider--large {
    height: 650px;
}
  
.card-slide {
    height: 100%;
    width: 100%;
    position: relative;
    overflow: hidden;
}
  
.card-slide__link {
    display: block;
    height: 100%;
    width: 100%;
    text-decoration: none;
}

/* Card flip styling */
.card-flip-container {
  position: relative;
  width: 100%;
  height: 100%;
  perspective: 1000px;
  transform-style: preserve-3d;
}

.card-side {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
