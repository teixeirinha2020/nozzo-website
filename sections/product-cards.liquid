<div class="product-cards-section color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  <div class="page-width">
    <!-- Navigation Tabs -->
    <div class="product-cards-navigation {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: 1;"
        {% endif %}
    >
      {% for block in section.blocks %}
        <button 
          class="nav-tab {% if forloop.first %}active{% endif %}" 
          data-tab="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.redirect_button_text | default: 'Product'}}
        </button>
      {% endfor %}
    </div>

    <!-- Cards Container -->
    <div class="product-cards-container {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: 2;"
          {% endif %}
    >
      <div class="product-cards-wrapper" data-current-slide="0">
        {% for block in section.blocks %}
          <div class="product-card {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index0 }}">
            <div class="card-content">
              <div class="card-image">
                {% if block.settings.image %}
                  <img 
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="placeholder-image">
                    <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
                      <rect width="100" height="100" fill="currentColor" opacity="0.1"/>
                      <path d="M30 40h40v20H30z" fill="currentColor" opacity="0.3"/>
                    </svg>
                  </div>
                {% endif %}
              </div>
              
              <div class="card-info">
                {% if block.settings.subheading_text != blank %}
                  <p class="card-subheading">{{ block.settings.subheading_text }}</p>
                {% endif %}
                
                {% if block.settings.heading_text != blank %}
                  <h1 class="card-heading">{{ block.settings.heading_text }}</h1>
                {% endif %}
                
                {% if block.settings.paragraph_text != blank %}
                  <p class="card-description">{{ block.settings.paragraph_text }}</p>
                {% endif %}
                
                {% if block.settings.button_text != blank %}
                  <a href="{{ block.settings.button_link | default: '#' }}" class="card-button">
                    {{ block.settings.button_text }}
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Mobile Navigation Dots -->
      <div class="mobile-dots">
        {% for block in section.blocks %}
          <button class="dot {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index0 }}"></button>
        {% endfor %}
      </div>
    </div>

    <!-- Touch/Drag Instructions -->
    <div class="drag-hint">
      <p>Arrasta para veres mais produtos</p>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const wrapper = section.querySelector('.product-cards-wrapper');
    const cards = section.querySelectorAll('.product-card');
    const navTabs = section.querySelectorAll('.nav-tab');
    const dots = section.querySelectorAll('.dot');
    let currentSlide = 0;
    let isAnimating = false;
    let startX = 0;
    let currentX = 0;
    let isDragging = false;

    // Initialize
    updateActiveElements(0);

    // Navigation tabs click
    navTabs.forEach((tab, index) => {
    tab.addEventListener('click', () => {
        if (!isAnimating && currentSlide !== index) {
        goToSlide(index);
        }
    });
    });

    // Dots click
    dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
        if (!isAnimating && currentSlide !== index) {
        goToSlide(index);
        }
    });
    });

    // Touch/Mouse events for dragging
    wrapper.addEventListener('mousedown', handleStart);
    wrapper.addEventListener('touchstart', handleStart, { passive: true });
    wrapper.addEventListener('mousemove', handleMove);
    wrapper.addEventListener('touchmove', handleMove, { passive: true });
    wrapper.addEventListener('mouseup', handleEnd);
    wrapper.addEventListener('touchend', handleEnd);
    wrapper.addEventListener('mouseleave', handleEnd);

    function handleStart(e) {
    if (isAnimating) return;
    isDragging = true;
    startX = e.type === 'mousedown' ? e.clientX : e.touches[0].clientX;
    wrapper.style.transition = 'none';
    wrapper.style.cursor = 'grabbing';
    }

    function handleMove(e) {
    if (!isDragging || isAnimating) return;
    e.preventDefault();
    currentX = (e.type === 'mousemove' ? e.clientX : e.touches[0].clientX) - startX;
    const maxDrag = wrapper.offsetWidth * 0.3;
    currentX = Math.max(-maxDrag, Math.min(maxDrag, currentX));
    wrapper.style.transform = `translateX(calc(-${currentSlide * 100}% + ${currentX}px))`;
    }

    function handleEnd() {
    if (!isDragging) return;
    isDragging = false;
    wrapper.style.cursor = 'grab';
    
    const threshold = wrapper.offsetWidth * 0.15;
    let newSlide = currentSlide;

    if (Math.abs(currentX) > threshold) {
        if (currentX > 0 && currentSlide > 0) {
        newSlide = currentSlide - 1;
        } else if (currentX < 0 && currentSlide < cards.length - 1) {
        newSlide = currentSlide + 1;
        }
    }

    // Always animate back to proper position
    wrapper.style.transition = 'transform 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
    
    if (newSlide !== currentSlide) {
        // Move to new slide
        goToSlide(newSlide);
    } else {
        // Snap back to current slide
        wrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
        setTimeout(() => {
        isAnimating = false;
        }, 600);
    }
    
    currentX = 0;
    }

    function goToSlide(index) {
    if (index === currentSlide && !isDragging) return;
    
    isAnimating = true;
    currentSlide = index;
    
    wrapper.style.transition = 'transform 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
    wrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
    
    updateActiveElements(index);
    
    setTimeout(() => {
        isAnimating = false;
    }, 600);
    }

    function updateActiveElements(index) {
    // Update cards
    cards.forEach((card, i) => {
        card.classList.toggle('active', i === index);
        if (i === index) {
        card.style.animationDelay = '0.2s';
        }
    });

    // Update navigation tabs
    navTabs.forEach((tab, i) => {
        tab.classList.toggle('active', i === index);
    });

    // Update dots
    dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
    });

    // Update wrapper data attribute
    wrapper.setAttribute('data-current-slide', index);
    }

    // Keyboard navigation
    section.addEventListener('keydown', (e) => {
    if (isAnimating) return;
    
    if (e.key === 'ArrowLeft' && currentSlide > 0) {
        goToSlide(currentSlide - 1);
    } else if (e.key === 'ArrowRight' && currentSlide < cards.length - 1) {
        goToSlide(currentSlide + 1);
    }
    });

    // Auto-advance (optional)
    {% if section.settings.auto_advance %}
    let autoAdvanceInterval = setInterval(() => {
    if (!isDragging && !isAnimating) {
        const nextSlide = currentSlide === cards.length - 1 ? 0 : currentSlide + 1;
        goToSlide(nextSlide);
    }
    }, {{ section.settings.auto_advance_delay | default: 5 | times: 1000 }});

    // Pause auto-advance on hover
    section.addEventListener('mouseenter', () => clearInterval(autoAdvanceInterval));
    section.addEventListener('mouseleave', () => {
    autoAdvanceInterval = setInterval(() => {
        if (!isDragging && !isAnimating) {
        const nextSlide = currentSlide === cards.length - 1 ? 0 : currentSlide + 1;
        goToSlide(nextSlide);
        }
    }, {{ section.settings.auto_advance_delay | default: 5 | times: 1000 }});
    });
    {% endif %}
});
</script>

<style>
.product-cards-section {
  padding: 60px 0;
  background: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
  position: relative;
  overflow: hidden;
}

.product-cards-navigation {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.nav-tab {
  background: transparent;
  border: 2px solid rgba(var(--color-foreground), 0.2);
  color: rgb(var(--color-foreground));
  padding: 12px 24px;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  position: relative;
  overflow: hidden;
}

.nav-tab::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgb(var(--color-foreground));
  transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: -1;
}

.nav-tab:hover::before,
.nav-tab.active::before {
  left: 0;
}

.nav-tab:hover,
.nav-tab.active {
  color: rgb(var(--color-background));
  border-color: rgb(var(--color-foreground));
  transform: translateY(-2px);
}

.product-cards-container {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}

.product-cards-wrapper {
  display: flex;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: grab;
  user-select: none;
}

.product-card {
  min-width: 100%;
  opacity: 0.6;
  transform: scale(0.95);
  transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  padding: 0 30px;
  box-sizing: border-box;
}

.product-card.active {
  opacity: 1;
  transform: scale(1);
}

.card-content {
  background: rgb(var(--color-background));
  border-radius: 32px;
  overflow: hidden;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  min-height: 500px;
  width: 100%;
}

.card-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 50%);
  pointer-events: none;
  z-index: 1;
}

.product-card.active .card-content {
  transform: translateY(-12px);
  box-shadow: 0 35px 70px rgba(0, 0, 0, 0.18);
}

.card-image {
  flex: 0 0 50%;
  width: 50%;
  min-height: 500px;
  background: #000;
  border-radius: 32px 0 0 32px;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.product-card.active .card-image img {
  transform: scale(1.05);
}

.placeholder-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(var(--color-foreground), 0.05);
  color: rgba(var(--color-foreground), 0.3);
}

.card-info {
  flex: 1;
  padding: 50px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: left;
  min-width: 0;
}

.card-subheading {
  font-size: 14px;
  color: rgba(var(--color-foreground), 0.7);
  margin: 0 0 12px 0;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  opacity: 0;
  transform: translateY(20px);
  animation: slideUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.product-card.active .card-subheading {
  animation-delay: 0.1s;
}

.card-heading {

  font-weight: 300;
  margin: 0 0 24px 0;
  line-height: 1;
  color: rgb(var(--color-foreground));
  opacity: 0;
  transform: translateY(30px);
  animation: slideUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.product-card.active .card-heading {
  animation-delay: 0.2s;
}

.card-description {
  line-height: 1.6;
  font-weight: 300;
  color: rgba(var(--color-foreground), 0.8);
  margin: 0 0 36px 0;
  opacity: 0;
  transform: translateY(20px);
  animation: slideUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.product-card.active .card-description {
  animation-delay: 0.3s;
}

.card-button {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: rgb(var(--color-foreground));
  color: rgb(var(--color-background));
  padding: 18px 36px;
  border-radius: 50px;
  text-decoration: none;
  font-weight: 600;
  font-size: 18px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  opacity: 0;
  transform: translateY(20px);
  animation: slideUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.product-card.active .card-button {
  animation-delay: 0.4s;
}

.card-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s;
}

.card-button:hover::before {
  left: 100%;
}

.card-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
}

.card-button svg {
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-button:hover svg {
  transform: translateX(4px);
}

.mobile-dots {
  display: none;
  justify-content: center;
  gap: 12px;
  margin-top: 30px;
}

.dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(var(--color-foreground), 0.3);
  border: none;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.dot.active {
  background: rgb(var(--color-foreground));
  transform: scale(1.2);
}

.drag-hint {
  text-align: center;
  margin-top: 20px;
  opacity: 0.6;
}

.drag-hint p {
  font-size: 14px;
  color: rgba(var(--color-foreground), 0.6);
  margin: 0;
}

@keyframes slideUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Large Desktop */
@media screen and (min-width: 1400px) {
  .product-cards-container {
    max-width: 1400px;
  }

  .product-card {
    padding: 0 40px;
  }

  .card-info {
    padding: 60px;
  }

}

/* Tablet Styles */
@media screen and (max-width: 1024px) {
  .product-cards-container {
    max-width: 900px;
  }

  .product-card {
    padding: 0 20px;
  }

  .card-content {
    min-height: 400px;
    border-radius: 24px;
  }

  .card-image {
    min-height: 400px;
    border-radius: 24px 0 0 24px;
  }

  .card-info {
    padding: 40px;
  }

  .card-heading {
    margin-bottom: 20px;
    line-height: 1;
  }

  .card-description {
    margin-bottom: 30px;
    line-height: 1.2;
  }

  .card-button {
    padding: 16px 32px;
    font-size: 16px;
    gap: 8px;
  }

  .product-card.active .card-content {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15);
  }
}

/* Mobile Landscape */
@media screen and (max-width: 768px) and (orientation: landscape) {
  .card-content {
    min-height: 300px;
  }

  .card-image {
    flex: 0 0 45%;
    min-height: 300px;
  }

  .card-info {
    padding: 24px;
  }
}

/* Mobile Portrait */
@media screen and (max-width: 768px) and (orientation: portrait) {
  .product-cards-section {
    padding: 40px 0;
  }

  .product-cards-navigation {
    margin-bottom: 30px;
  }

  .nav-tab {
    padding: 10px 20px;
    font-size: 12px;
  }

  .card-content {
    flex-direction: column;
    border-radius: 16px;
    min-height: auto;
  }


  .card-image {
    flex: none;
    width: 100%;
    min-height: 280px;
    border-radius: 16px 16px 0 0;
  }

  .card-info {
    flex: none;
    padding: 30px 24px;
  }

  .card-description {
    line-height: 1.2;
  }
}

/* Small Mobile */
@media screen and (max-width: 480px) {
  .product-card {
    padding: 0 10px;
  }

  .card-content {
    border-radius: 12px;
  }

  .card-image {
    min-height: 240px;
    border-radius: 12px 12px 0 0;
  }

  .card-info {
    padding: 24px 20px;
  }

  .card-heading {
    line-height: 1.2; 
  }

  .card-description {
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .card-button {
    padding: 14px 28px;
    font-size: 14px;
  }

  .nav-tab {
    padding: 8px 16px;
    font-size: 11px;
    margin: 2px;
  }

  .product-cards-navigation {
    gap: 4px;
  }
}

/* Extra Small Mobile */
@media screen and (max-width: 360px) {
  .card-info {
    padding: 20px 16px;
  }

  .card-subheading {
    font-size: 12px;
  }


  .card-button {
    padding: 12px 24px;
    font-size: 13px;
  }

  .nav-tab {
    padding: 6px 12px;
    font-size: 10px;
  }
}

/* Color Scheme Variations */
.color-accent-1 {
  background: rgb(var(--color-base-accent-1));
  color: rgb(var(--color-base-text));
}

.color-accent-2 {
  background: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-text));
}

.color-inverse {
  background: rgb(var(--color-foreground));
  color: rgb(var(--color-background));
}
</style>

