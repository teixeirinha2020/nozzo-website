  <script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.js" async></script>
<script>
  // Replace your existing masonry script with this:
function initMasonry() {
    const grid = document.querySelector('.trusted-reviews-grid');
    if (grid && window.Masonry) {
      // Wait for images to load before initializing masonry
      const images = grid.querySelectorAll('img');
      let loadedImages = 0;
      const totalImages = images.length;
      
      function checkAllImagesLoaded() {
        loadedImages++;
        if (loadedImages === totalImages) {
          initMasonryGrid();
        }
      }
      
      function initMasonryGrid() {
        new Masonry(grid, {
          itemSelector: '.grid-item',
          columnWidth: '.grid-sizer',
          percentPosition: true,
          gutter: 20
        });
      }
      
      if (totalImages === 0) {
        // No images, initialize immediately
        initMasonryGrid();
      } else {
        // Wait for all images to load
        images.forEach(img => {
          if (img.complete) {
            checkAllImagesLoaded();
          } else {
            img.addEventListener('load', checkAllImagesLoaded);
            img.addEventListener('error', checkAllImagesLoaded); // Handle broken images
          }
        });
      }
    } else if (!window.Masonry) {
      // Masonry not loaded yet, try again in 100ms
      setTimeout(initMasonry, 100);
    }
  }
  
  document.addEventListener('DOMContentLoaded', initMasonry);
  
  // Also try to reinitialize when the window is resized
  window.addEventListener('resize', function() {
    const grid = document.querySelector('.trusted-reviews-grid');
    if (grid && window.Masonry) {
      // Get the masonry instance and relayout
      const msnry = Masonry.data(grid);
      if (msnry) {
        msnry.layout();
      }
    }
  });
</script>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    // Video functionality
    const videoBlocks = document.querySelectorAll('[data-video-block]');
    
    videoBlocks.forEach(block => {
      const video = block.querySelector('.video-element');
      const cover = block.querySelector('.video-cover');
      const playButton = block.querySelector('.video-play-button');
      const muteButton = block.querySelector('[data-mute-toggle]');
      const muteIcon = muteButton?.querySelector('.mute-icon');
      const unmuteIcon = muteButton?.querySelector('.unmute-icon');
      
      if (!video) return;
      video.playsInline        = true;
      video.webkitPlaysInline  = true;

      let isPlaying = false;
      let isMuted = true;
      
      // Play/Pause functionality
      block.addEventListener('click', function(e) {
        if (e.target.closest('[data-mute-toggle]')) return;
        
        if (isPlaying) {
          video.pause();
          isPlaying = false;
          block.classList.remove('video-playing');
        } else {
          video.play();
          isPlaying = true;
          block.classList.add('video-playing');
        }
      });
      
      // Mute/Unmute functionality
      if (muteButton) {
        muteButton.addEventListener('click', function(e) {
          e.stopPropagation();
          
          if (isMuted) {
            video.muted = false;
            isMuted = false;
            muteIcon.style.display = 'none';
            unmuteIcon.style.display = 'block';
          } else {
            video.muted = true;
            isMuted = true;
            muteIcon.style.display = 'block';
            unmuteIcon.style.display = 'none';
          }
        });
      }
      
      // Reset when video ends
      video.addEventListener('ended', function() {
        isPlaying = false;
        block.classList.remove('video-playing');
      });
    });
  });
  </script>
  
