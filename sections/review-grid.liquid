                      </svg>
                  {% endcase %}
                </div>
                
                {% if block.settings.comment != blank %}
                  <div class="social-content">{{ block.settings.comment }}</div>
                {% endif %}
                
                {% if block.settings.date_time != blank %}
                  <div class="social-date">{{ block.settings.date_time }}</div>
                {% endif %}
              </a>
  
            {% when 'image' %}
              <div class="review-block-image">
                <div class="image-content">
                  {% if block.settings.image %}
                    {{ block.settings.image | image_url: width: 1080 |  image_tag: alt: '1' , class: 'block-image' }}
                  {% endif %}
                  
                  {% if block.settings.title != blank or block.settings.subtitle != blank %}
                    <div class="image-overlay">
                      {% if block.settings.icon_image %}
                       {{ block.settings.icon_image | image_url: width: 100 | image_tag: class: 'image-icon' }}
                      {% endif %}
                      {% if block.settings.title != blank %}
                        <div class="image-title"><h2>{{ block.settings.title }}</h2></div>
                      {% endif %}
                      {% if block.settings.subtitle != blank %}
                        <div class="image-subtitle"><p>{{ block.settings.subtitle }}</p></div>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
  
            {% when 'text_with_image' %}
              <div class="review-block-text">
                <div class="text-header">
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 100 }}" alt="Text block image" class="text-icon">
                  {% endif %}
                  
                  <div class="text-content">
                    {% if block.settings.title != blank %}
                      <div class="text-title">{{ block.settings.title }}</div>
                    {% endif %}
                    {% if block.settings.subtitle != blank %}
                      <div class="text-subtitle">{{ block.settings.subtitle }}</div>
                    {% endif %}
                  </div>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
  
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    // Video functionality
    const videoBlocks = document.querySelectorAll('[data-video-block]');
    
    videoBlocks.forEach(block => {
      const video = block.querySelector('.video-element');
      const cover = block.querySelector('.video-cover');
      const playButton = block.querySelector('.video-play-button');
      const muteButton = block.querySelector('[data-mute-toggle]');
      const muteIcon = muteButton?.querySelector('.mute-icon');
      const unmuteIcon = muteButton?.querySelector('.unmute-icon');
      
      if (!video) return;
      
      let isPlaying = false;
      let isMuted = true;
      
      // Play/Pause functionality
      block.addEventListener('click', function(e) {
        if (e.target.closest('[data-mute-toggle]')) return;
        
        if (isPlaying) {
          video.pause();
          isPlaying = false;
          block.classList.remove('video-playing');
        } else {
          video.play();
          isPlaying = true;
          block.classList.add('video-playing');
        }
      });
      
      // Mute/Unmute functionality
      if (muteButton) {
        muteButton.addEventListener('click', function(e) {
          e.stopPropagation();
          
          if (isMuted) {
            video.muted = false;
            isMuted = false;
            muteIcon.style.display = 'none';
            unmuteIcon.style.display = 'block';
          } else {
            video.muted = true;
            isMuted = true;
            muteIcon.style.display = 'block';
            unmuteIcon.style.display = 'none';
          }
        });
      }
      
      // Reset when video ends
      video.addEventListener('ended', function() {
        isPlaying = false;
        block.classList.remove('video-playing');
      });
    });
  });
  </script>
  
