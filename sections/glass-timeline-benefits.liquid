{% schema %}
  {
    "name": "Glass Timeline Benefits",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "The best sleep you've ever had"
      },
      {
        "type": "color",
        "id": "title_color",
        "label": "Title Color",
        "default": "#ffffff"
      },
      {
        "type": "textarea",
        "id": "subtitle",
        "label": "Subtitle",
        "default": "The Pod is clinically proven to deliver real results for your sleep, every night"
      },
      {
        "type": "color",
        "id": "subtitle_color",
        "label": "Subtitle Color",
        "default": "#cccccc"
      },
      {
        "type": "color_background",
        "id": "background_gradient",
        "label": "Background Gradient",
        "default": "radial-gradient(ellipse at center, #1c1e2b 0%, #0f101b 60%, #090a13 100%)"
      },
      {
        "type": "color",
        "id": "timeline_color",
        "label": "Timeline Line & Bullet Color",
        "default": "#ffffff"
      }
    ],
    "blocks": [
      {
        "type": "benefit",
        "name": "Benefit",
        "limit": 4,
        "settings": [
          {
            "type": "text",
            "id": "small_text",
            "label": "Small Text (e.g., Up to 44%)",
            "default": "Up to 44%"
          },
          {
            "type": "text",
            "id": "main_text",
            "label": "Main Text",
            "default": "Less time to fall asleep"
          },
          {
            "type": "color",
            "id": "box_color",
            "label": "Benefit Box Background Overlay",
            "default": "rgba(255, 255, 255, 0.04)"
          },
          {
            "type": "range",
            "id": "benefit_height",
            "label": "Choose the Benefit Box Height (50-200)",
            "unit": "px",
            "min": 50,
            "max": 200,
            "step": 2,
            "default": 124
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Glass Timeline Benefits",
        "category": "Custom Content",
        "blocks": [
          { "type": "benefit" },
          { "type": "benefit" },
          { "type": "benefit" },
          { "type": "benefit" }
        ]
      }
    ]
  }
  {% endschema %}
  
  <style>
  .glass-timeline {
    background: {{ section.settings.background_gradient }};
    padding: 4rem 5.5rem 0;
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .glass-timeline__container {
    max-width: 1440px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .glass-timeline__title {
    font-size: 6rem;
    letter-spacing: -1px;
    max-width: 500px;
    font-weight: 300;
    color: {{ section.settings.title_color }};
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .glass-timeline__subtitle {
    font-size: 1.6rem;
    letter-spacing: -0.5px;
    max-width: 700px;
    color: {{ section.settings.subtitle_color }};
    font-weight: 300;
    margin-bottom: 3.5rem;
    line-height: 1;
  }
  .glass-timeline__timeline {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    width: 100%;
    min-height: 400px;
  }
  .glass-timeline__benefit {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3rem;
  }

  .glass-timeline__line-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: fit-content;
  }

  .glass-timeline__box {
    background: var(--box-color, rgba(255,255,255,0.05));
    color: #fff;
    padding: 1.5rem;
    border-radius: .5rem;
    border: 1.418px solid rgba(255, 255, 255, .02);
    background: rgba(255, 255, 255, .02);
    box-shadow: 2.836px 2.836px 90.745px 0 rgba(0, 0, 0, .55);
    -webkit-backdrop-filter: blur(8.5px);
    backdrop-filter: blur(8.5px);
    min-width: 100px;
    max-width: 300px;
    gap:12px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    margin-left: 9px;
  }
  .glass-timeline__box:hover {
    transform: translateY(-6px);
  }
  .glass-timeline__small {
    font-size: 2rem;
    font-weight: 300;
    opacity: .8;
    line-height: normal;
    letter-spacing: -0.5px;
  }
  .glass-timeline__main {
    font-size: 2.7rem;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.5px;
    width: 10ch;
  }
  
  /* Timeline parts */
  .glass-timeline__bullet,
  .glass-timeline__line,
  .glass-timeline__tick,
  .glass-timeline__tick--large {
    display: block !important;
  }
  .glass-timeline__bullet {
    width: 18px;
    height: 18px;
    background: {{ section.settings.timeline_color }};
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(0,0,0,0.25);
    z-index: 2;
  }
  .glass-timeline__line {
    background: {{ section.settings.timeline_color }};
  }
  .glass-timeline__ticks {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    height: 14px;
    padding: 0 1rem;
    z-index: 0;
  }
  .glass-timeline__tick {
    width: 1px;
    height: 10px;
    background: #fff;
  }
  .glass-timeline__tick--large {
    height: 16px;
  }
  
  /* Mobile */
  @media (max-width: 768px) {
    .glass-timeline {
      padding: 4rem 1.5rem;
    }
  .glass-timeline__container {
    align-items: flex-start;
  }
  .glass-timeline__title {
      font-size: 3.6rem;
      text-align: start;
      max-width: 14ch;
    }
    .glass-timeline__subtitle {
      font-size: 1.5rem;
      text-align: start;
      line-height: normal;
    }
    .glass-timeline__timeline {
      flex-direction: column;
      align-items: flex-start;
      min-height: auto;
      gap: 2.5rem;
    }
    .glass-timeline__benefit {
      flex-direction: row-reverse;
      align-items: flex-start;
      margin-bottom: 0;
      gap: 1rem
    }
    .glass-timeline__box {
      gap: 0.25rem;
      margin: 0;
    }

    .glass-timeline__main {
      font-size: 2.4rem;
      line-height: 1.3;
      width: 10ch;
    }

    .glass-timeline__line-container {
      flex-direction: row-reverse;
      align-items: center;
      margin-top: 9px;
    }

    .glass-timeline__box {

    }
    .glass-timeline__bullet {
      height: 9px;
      width: 9px;
    }
  }
  </style>
  
  <div class="glass-timeline">
    <div class="glass-timeline__container">
      <h2 class="glass-timeline__title">{{ section.settings.title }}</h2>
      <p class="glass-timeline__subtitle">{{ section.settings.subtitle }}</p>
  
      <div class="glass-timeline__timeline">
        {% for block in section.blocks %}
          <div class="glass-timeline__benefit">
            <div class="glass-timeline__box" style="--box-color: {{ block.settings.box_color }}">
              <div class="glass-timeline__small">{{ block.settings.small_text }}</div>
              <div class="glass-timeline__main">{{ block.settings.main_text }}</div>
            </div>
            <div class="glass-timeline__line-container">
              <div class="glass-timeline__bullet"></div>
              <div class="glass-timeline__line height-{{ block.settings.benefit_height }}"></div>
              <style>
                .height-{{ block.settings.benefit_height }} {
                  height: calc({{ block.settings.benefit_height }}px - 30px);
                  width: 1px;
                }
                @media (max-width: 768px) {
                  .height-{{ block.settings.benefit_height }} {
                    width: calc({{ block.settings.benefit_height }}px - 30px);
                    height: 1px;
                  }
                }

              </style>
            </div>
          </div>
        {% endfor %}
      </div>
  
      <div class="glass-timeline__ticks">
        {% assign total_ticks = section.blocks.size | times: 4 %}
        {% assign middle_tick = total_ticks | divided_by: 2 %}
        {% assign second_last_tick = total_ticks | minus: 1 %}
        {% for i in (1..total_ticks) %}
          {% if i == middle_tick or i == second_last_tick %}
            <div class="glass-timeline__tick glass-timeline__tick--large"></div>
          {% else %}
            <div class="glass-timeline__tick"></div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
  