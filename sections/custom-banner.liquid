{%- if section.settings.enable_animations -%}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
{%- endif -%}

<div id="CustomBanner-{{ section.id }}" class="custom-banner custom-banner--{{ section.settings.section_height }} custom-banner--{{ section.settings.content_position_desktop }}-desktop custom-banner--{{ section.settings.content_position_mobile }}-mobile"
  data-section-id="{{ section.id }}"
  data-enable-animations="{{ section.settings.enable_animations }}"
  data-animation-type="{{ section.settings.animation_type }}"
  data-animation-delay="{{ section.settings.animation_delay }}"
  data-animation-trigger="{{ section.settings.animation_trigger }}"
>
  <div class="custom-banner__background">
    {% if section.settings.background_type == 'image' %}
      <div class="custom-banner__image">
        {% if section.settings.background_image != blank %}
          {% assign desktop_img_url = section.settings.background_image | img_url: 'master' %}
          <img class="custom-banner__image-desktop" 
               src="{{ desktop_img_url }}" 
               alt="{{ section.settings.heading | default: 'Banner' }}" 
               loading="eager"
               width="{{ section.settings.background_image.width }}"
               height="{{ section.settings.background_image.height }}">
        {% endif %}
        
        {% if section.settings.background_image_mobile != blank %}
          {% assign mobile_img_url = section.settings.background_image_mobile | img_url: 'master' %}
          <img class="custom-banner__image-mobile" 
               src="{{ mobile_img_url }}" 
               alt="{{ section.settings.heading | default: 'Banner' }}" 
               loading="eager"
               width="{{ section.settings.background_image_mobile.width }}"
               height="{{ section.settings.background_image_mobile.height }}">
        {% endif %}
      </div>
    {% elsif section.settings.background_type == 'video' %}
      <div class="custom-banner__video-container">
        {% if section.settings.background_video_url != blank %}
          <video 
            class="custom-banner__video custom-banner__video-desktop" 
            autoplay 
            playsinline
            {% if section.settings.loop_video %}loop{% endif %} 
            {% if section.settings.mute_video %}muted{% endif %}
            preload="auto"
          >
            <source src="{{ section.settings.background_video_url }}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
          
          {% if section.settings.background_video_url_mobile != blank %}
            <video 
              class="custom-banner__video custom-banner__video-mobile" 
              autoplay 
              playsinline
              {% if section.settings.loop_video %}loop{% endif %} 
              {% if section.settings.mute_video %}muted{% endif %}
              preload="auto"
            >
              <source src="{{ section.settings.background_video_url_mobile }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          {% else %}
            <!-- Create a separate mobile video element that's a clone of desktop -->
            <video 
              class="custom-banner__video custom-banner__video-mobile custom-banner__video-mobile-fallback" 
              autoplay 
              playsinline
              {% if section.settings.loop_video %}loop{% endif %} 
              {% if section.settings.mute_video %}muted{% endif %}
              preload="auto"
            >
              <source src="{{ section.settings.background_video_url }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          {% endif %}
        {% elsif section.settings.background_video.type == 'youtube' %}
          <div class="custom-banner__iframe-wrapper">
            <iframe 
              class="custom-banner__iframe"
              src="https://www.youtube.com/embed/{{ section.settings.background_video.id }}?playsinline=1&controls=0&rel=0&autoplay=1&mute={{ section.settings.mute_video | default: 1 }}&loop={{ section.settings.loop_video | default: 1 }}&playlist={{ section.settings.background_video.id }}"
              frameborder="0"
              allowfullscreen
              allow="autoplay; encrypted-media"
            ></iframe>
          </div>
        {% elsif section.settings.background_video.type == 'vimeo' %}
          <div class="custom-banner__iframe-wrapper">
            <iframe 
              class="custom-banner__iframe"
              src="https://player.vimeo.com/video/{{ section.settings.background_video.id }}?background=1&autoplay=1&loop={{ section.settings.loop_video | default: 1 }}&byline=0&title=0{% if section.settings.mute_video %}&muted=1{% endif %}"
              frameborder="0"
              allowfullscreen
              allow="autoplay; encrypted-media"
            ></iframe>
          </div>
        {% endif %}
      </div>
    {% else %}
      <div class="custom-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}
    
    <div class="custom-banner__overlay"></div>
  </div>
  
  <div class="custom-banner__content-container">
    <div class="custom-banner__content" style="--space-between-desktop: {{ section.settings.space_between_desktop }}px; --space-between-mobile: {{ section.settings.space_between_mobile }}px;">
      <div class="custom-banner__text-content js-animate-element">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'title' %}
              {% assign title_tag = 'h2' %}
              {% if block.settings.title_size == 'h1' %}
                {% assign title_tag = 'h1' %}
              {% elsif block.settings.title_size == 'h2' %}
                {% assign title_tag = 'h2' %}
              {% elsif block.settings.title_size == 'h3' %}
                {% assign title_tag = 'h3' %}
              {% elsif block.settings.title_size == 'h4' %}
                {% assign title_tag = 'h4' %}
              {% elsif block.settings.title_size == 'h5' %}
                {% assign title_tag = 'h5' %}
              {% elsif block.settings.title_size == 'h6' %}
                {% assign title_tag = 'h6' %}
              {% else %}
                {% assign title_tag = 'div' %}
              {% endif %}
            
              <{{ title_tag }} 
                class="custom-banner__title custom-banner__title--{{ block.settings.title_size }} js-animate-child"
                style="{% if block.settings.title_color contains 'gradient' %}background: {{ block.settings.title_color }};-webkit-background-clip: text;-webkit-text-fill-color: transparent;{% else %}color: {{ block.settings.title_color }};{% endif %}
                       font-family: {{ block.settings.title_font.family | escape }}, {{ block.settings.title_font.fallback_families | escape }};
                       font-weight: {{ block.settings.title_weight }};"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.title_text }}
              </{{ title_tag }}>
            
            {% when 'span' %}
              <div class="custom-banner__paragraph custom-banner__paragraph--{{ block.settings.span_size }} js-animate-child"
                style="color: {{ block.settings.span_color }};
                       font-family: {{ block.settings.span_font.family | escape }}, {{ block.settings.span_font.fallback_families | escape }};
                       font-weight: {{ block.settings.span_weight }};"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.span_text }}
              </div>
              
          {% endcase %}
        {% endfor %}
      </div>
      
      <div class="custom-banner__button-container js-animate-element">
        {% for block in section.blocks %}
          {% if block.type == 'button' %}
            <a href="{{ block.settings.button_link }}" 
              class="custom-banner__button custom-banner__button--{{ block.settings.button_size }} custom-banner__button--animation-{{ block.settings.button_animation }} js-animate-child"
              style="color: {{ block.settings.button_text_color }};
                     background-color: {{ block.settings.button_bg_color }};
                     font-family: {{ block.settings.button_font.family | escape }}, {{ block.settings.button_font.fallback_families | escape }};
                     font-weight: {{ block.settings.button_weight }};
                     border-radius: {{ block.settings.button_radius }}px;"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% if section.settings.enable_animations %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    function initBannerAnimations() {
      const banner = document.getElementById('CustomBanner-{{ section.id }}');
      if (!banner) return;
      
      const enableAnimations = banner.dataset.enableAnimations === 'true';
      if (!enableAnimations) return;
      
      // Check if GSAP and ScrollTrigger are loaded
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        // Wait and try again in 500ms
        setTimeout(initBannerAnimations, 500);
        return;
      }
      
      // Register ScrollTrigger plugin
      gsap.registerPlugin(ScrollTrigger);
      
      // Get animation settings
      const animationType = banner.dataset.animationType;
      const animationDelay = parseFloat(banner.dataset.animationDelay);
      const animationTrigger = banner.dataset.animationTrigger || 'onload'; // Default to onload
      
      // Set initial states based on animation type
      const animateElements = banner.querySelectorAll('.js-animate-child');
      animateElements.forEach((element, index) => {
        switch (animationType) {
          case 'fade':
            gsap.set(element, { opacity: 0 });
            break;
          case 'slide_up':
            gsap.set(element, { opacity: 0, y: 30 });
            break;
          case 'slide_left':
            gsap.set(element, { opacity: 0, x: -30 });
            break;
          case 'slide_right':
            gsap.set(element, { opacity: 0, x: 30 });
            break;
          case 'scale':
            gsap.set(element, { opacity: 0, scale: 0.9 });
            break;
          default:
            gsap.set(element, { opacity: 0 });
        }
      });
      
      // Create animation timeline
      let tl = gsap.timeline();
      
      // Apply ScrollTrigger only if animation trigger is scroll
      if (animationTrigger === 'scroll') {
        tl = gsap.timeline({
          scrollTrigger: {
            trigger: banner,
            start: "top 80%",
            toggleActions: "play none none none"
          }
        });
      }
      
      // Add animations to timeline
      animateElements.forEach((element, index) => {
        const delay = (animationTrigger === 'onload') ? 0.3 + (index * animationDelay) : index * animationDelay;
        
        switch (animationType) {
          case 'fade':
            tl.to(element, { opacity: 1, duration: 0.8, ease: "power2.out" }, delay);
            break;
          case 'slide_up':
            tl.to(element, { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" }, delay);
            break;
          case 'slide_left':
            tl.to(element, { opacity: 1, x: 0, duration: 0.8, ease: "power2.out" }, delay);
            break;
          case 'slide_right':
            tl.to(element, { opacity: 1, x: 0, duration: 0.8, ease: "power2.out" }, delay);
            break;
          case 'scale':
            tl.to(element, { opacity: 1, scale: 1, duration: 0.8, ease: "back.out(1.7)" }, delay);
            break;
          default:
            tl.to(element, { opacity: 1, duration: 0.8, ease: "power2.out" }, delay);
        }
      });
    }
    
    // Run initialization
    initBannerAnimations();
    
    // Listen for Shopify section load/reload events
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initBannerAnimations();
      }
    });
  });
</script>
{% endif %}

<style>
  .custom-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    border-radius: 0 0 20px 20px;
  }
  
  /* Heights */
  .custom-banner--small {
    height: 400px;
  }
  
  .custom-banner--medium {
    height: 600px;
  }
  
  .custom-banner--big {
    height: 800px;
  }
  
  .custom-banner--vh {
    height: 100vh;
  }
  
  .custom-banner--adapt {
    min-height: 400px;
  }
  
  /* Background */
  .custom-banner__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  .custom-banner__image,
  .custom-banner__video-container,
  .custom-banner__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .custom-banner__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  .custom-banner__image-desktop {
