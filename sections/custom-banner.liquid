<script>
document.addEventListener('DOMContentLoaded', function() {
  var banner = document.getElementById('CustomBanner-{{ section.id }}');
  if (!banner) return;

  // Find controls anywhere in the section
  var pauseBtn = banner.querySelector('.custom-banner__pause-btn');
  var unmuteBtn = banner.querySelector('.custom-banner__unmute-btn');

  function getVideos() {
    // Return all video elements in the banner
    return Array.from(banner.querySelectorAll('video'));
  }

  // Pause/Play toggle
  if (pauseBtn) {
    pauseBtn.addEventListener('click', function() {
      var videos = getVideos();
      var isPaused = videos.every(function(video) { return video.paused; });
      if (isPaused) {
        videos.forEach(function(video) { video.play(); });
        pauseBtn.querySelector('.custom-banner__btn-text').textContent = 'Pause';
        pauseBtn.querySelector('.custom-banner__pause-icon').style.display = 'block';
        pauseBtn.querySelector('.custom-banner__play-icon').style.display = 'none';
      } else {
        videos.forEach(function(video) { video.pause(); });
        pauseBtn.querySelector('.custom-banner__btn-text').textContent = 'Play';
        pauseBtn.querySelector('.custom-banner__pause-icon').style.display = 'none';
        pauseBtn.querySelector('.custom-banner__play-icon').style.display = 'block';
      }
    });
  }

  // Mute/Unmute toggle
  if (unmuteBtn) {
    unmuteBtn.addEventListener('click', function() {
      var videos = getVideos();
      var isMuted = videos.every(function(video) { return video.muted; });
      if (isMuted) {
        videos.forEach(function(video) { video.muted = false; });
        unmuteBtn.querySelector('.custom-banner__btn-text').textContent = 'Mute';
        unmuteBtn.querySelector('.custom-banner__unmute-icon').style.display = 'none';
        unmuteBtn.querySelector('.custom-banner__mute-icon').style.display = 'block';
      } else {
        videos.forEach(function(video) { video.muted = true; });
        unmuteBtn.querySelector('.custom-banner__btn-text').textContent = 'Unmute';
        unmuteBtn.querySelector('.custom-banner__unmute-icon').style.display = 'block';
        unmuteBtn.querySelector('.custom-banner__mute-icon').style.display = 'none';
      }
    });
  }

  // Set initial button text and icons based on video state
  function setInitialButtonStates() {
    var videos = getVideos();
    var isPaused = videos.every(function(video) { return video.paused; });
    var isMuted = videos.every(function(video) { return video.muted; });
    
    if (pauseBtn) {
      pauseBtn.querySelector('.custom-banner__btn-text').textContent = isPaused ? 'Play' : 'Pause';
      pauseBtn.querySelector('.custom-banner__pause-icon').style.display = isPaused ? 'none' : 'block';
      pauseBtn.querySelector('.custom-banner__play-icon').style.display = isPaused ? 'block' : 'none';
    }
    
    if (unmuteBtn) {
      unmuteBtn.querySelector('.custom-banner__btn-text').textContent = isMuted ? 'Unmute' : 'Mute';
      unmuteBtn.querySelector('.custom-banner__unmute-icon').style.display = isMuted ? 'block' : 'none';
      unmuteBtn.querySelector('.custom-banner__mute-icon').style.display = isMuted ? 'none' : 'block';
    }
  }

  setInitialButtonStates();

  // Update button text and icons if user interacts with video controls directly
  getVideos().forEach(function(video) {
    video.addEventListener('play', setInitialButtonStates);
    video.addEventListener('pause', setInitialButtonStates);
    video.addEventListener('volumechange', setInitialButtonStates);
  });
});
</script>