<script>
document.addEventListener('DOMContentLoaded', function() {
  var banner = document.getElementById('CustomBanner-{{ section.id }}');
  if (!banner) return;

  // Find controls anywhere in the section
  var pauseBtn = banner.querySelector('.custom-banner__pause-btn');
  var unmuteBtn = banner.querySelector('.custom-banner__unmute-btn');

  function getVideos() {
    // Return all video elements in the banner
    return Array.from(banner.querySelectorAll('video'));
  }

  // Pause/Play toggle
  if (pauseBtn) {
    pauseBtn.addEventListener('click', function() {
      var videos = getVideos();
      var isPaused = videos.every(function(video) { return video.paused; });
      if (isPaused) {
        videos.forEach(function(video) { video.play(); });
        pauseBtn.querySelector('.custom-banner__btn-text').textContent = 'Pause';
      } else {
        videos.forEach(function(video) { video.pause(); });
        pauseBtn.querySelector('.custom-banner__btn-text').textContent = 'Play';
      }
    });
  }

  // Mute/Unmute toggle
  if (unmuteBtn) {
    unmuteBtn.addEventListener('click', function() {
      var videos = getVideos();
      var isMuted = videos.every(function(video) { return video.muted; });
      if (isMuted) {
        videos.forEach(function(video) { video.muted = false; });
        unmuteBtn.querySelector('.custom-banner__btn-text').textContent = 'Mute';
      } else {
        videos.forEach(function(video) { video.muted = true; });
        unmuteBtn.querySelector('.custom-banner__btn-text').textContent = 'Unmute';
      }
    });
  }

  // Set initial button text based on video state
  function setInitialButtonStates() {
    var videos = getVideos();
    var isPaused = videos.every(function(video) { return video.paused; });
    var isMuted = videos.every(function(video) { return video.muted; });
    if (pauseBtn) pauseBtn.querySelector('.custom-banner__btn-text').textContent = isPaused ? 'Play' : 'Pause';
    if (unmuteBtn) unmuteBtn.querySelector('.custom-banner__btn-text').textContent = isMuted ? 'Unmute' : 'Mute';
  }

  setInitialButtonStates();

  // Update button text if user interacts with video controls directly
  getVideos().forEach(function(video) {
    video.addEventListener('play', setInitialButtonStates);
    video.addEventListener('pause', setInitialButtonStates);
    video.addEventListener('volumechange', setInitialButtonStates);
  });
});
</script>