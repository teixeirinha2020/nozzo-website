    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    gap: 10px;
    transition: background 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
