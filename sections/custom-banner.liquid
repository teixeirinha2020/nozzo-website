        },
        {
          "type": "font_picker",
          "id": "span_font",
          "label": "Font",
          "default": "helvetica_n4"
        },
        {
          "type": "select",
          "id": "span_weight",
          "label": "Font Weight",
          "options": [
            {
              "value": "400",
              "label": "Regular"
            },
            {
              "value": "500",
              "label": "Medium"
            },
            {
              "value": "600",
              "label": "Semibold"
            },
            {
              "value": "700",
              "label": "Bold"
            }
          ],
          "default": "400"
        },
        {
          "type": "select",
          "id": "span_size",
          "label": "Font Size",
          "options": [
