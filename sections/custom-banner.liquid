{% schema %}
{
  "name": "Custom Video Banner",
  "settings": [
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "big",
          "label": "Big"
        },
        {
          "value": "vh",
          "label": "Viewport Height (100vh - 38px)"
        },
        {
          "value": "adapt",
          "label": "Adapt to Content"
        }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Video Background Settings"
    },
    {
      "type": "video",
      "id": "background_video_desktop",
      "label": "Background Video (Desktop)",
      "info": "Recommended: MP4, 1800x1000px"
    },
    {
      "type": "video",
      "id": "background_video_mobile",
      "label": "Background Video (Mobile)",
      "info": "Recommended: MP4, 800x1200px. If not selected, desktop video will be used."
    },
    {
      "type": "url",
      "id": "background_video_url_desktop",
      "label": "Fallback Video URL (Desktop)",
      "info": "Used if video picker fails. MP4 recommended."
    },
    {
      "type": "url",
      "id": "background_video_url_mobile",
      "label": "Fallback Video URL (Mobile)",
      "info": "Used if video picker fails. If not provided, desktop fallback will be used."
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "select",
      "id": "content_position_desktop",
      "label": "Content Position (Desktop)",
      "options": [
        { "value": "top_left", "label": "Top Left Corner" },
        { "value": "top_center", "label": "Top Center" },
        { "value": "top_right", "label": "Top Right Corner" },
        { "value": "middle_left", "label": "Middle Left" },
        { "value": "middle_center", "label": "Middle Center" },
        { "value": "middle_right", "label": "Middle Right" },
        { "value": "bottom_left", "label": "Bottom Left Corner" },
        { "value": "bottom_center", "label": "Bottom Center" },
        { "value": "bottom_right", "label": "Bottom Right Corner" }
      ],
      "default": "middle_center"
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "label": "Content Position (Mobile)",
      "options": [
        { "value": "top_left", "label": "Top Left Corner" },
        { "value": "top_center", "label": "Top Center" },
        { "value": "top_right", "label": "Top Right Corner" },
        { "value": "middle_left", "label": "Middle Left" },
        { "value": "middle_center", "label": "Middle Center" },
        { "value": "middle_right", "label": "Middle Right" },
        { "value": "bottom_left", "label": "Bottom Left Corner" },
        { "value": "bottom_center", "label": "Bottom Center" },
        { "value": "bottom_right", "label": "Bottom Right Corner" }
      ],
      "default": "middle_center"
    },
    {
      "type": "select",
      "id": "content_justify",
      "label": "Content Justification",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "control_btn_bg_color",
      "label": "Control Button Background Color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "control_btn_icon_color",
      "label": "Control Button Icon/Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "title_text",
          "label": "Title Text",
          "default": "Your Title Here"
        },
        {
          "type": "color_background",
          "id": "title_color",
          "label": "Title Color",
          "default": "#000000"
        },
        {
          "type": "font_picker",
          "id": "title_font",
          "label": "Title Font",
          "default": "helvetica_n4"
        },
        {
          "type": "select",
          "id": "title_weight",
          "label": "Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "700"
        },
        {
          "type": "select",
          "id": "title_size",
          "label": "Font Size",
          "options": [
            { "value": "ultra", "label": "Ultra (Largest)" },
            { "value": "mega", "label": "Mega" },
            { "value": "hero", "label": "Hero" },
            { "value": "display", "label": "Display" },
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6 (Smallest)" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "span",
      "name": "Paragraph",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "span_text",
          "label": "Paragraph Text",
          "default": "Add your paragraph text here to describe your product, service, or promotion."
        },
        {
          "type": "color",
          "id": "span_color",
          "label": "Text Color",
          "default": "#666666"
        },
        {
          "type": "font_picker",
          "id": "span_font",
          "label": "Font",
          "default": "helvetica_n4"
        },
        {
          "type": "select",
          "id": "span_weight",
          "label": "Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "400"
        },
        {
          "type": "select",
          "id": "span_size",
          "label": "Font Size",
          "options": [
            { "value": "3xl", "label": "3X Large" },
            { "value": "2xl", "label": "2X Large" },
            { "value": "xl", "label": "Extra Large" },
            { "value": "lg", "label": "Large" },
            { "value": "md", "label": "Medium" },
            { "value": "sm", "label": "Small" },
            { "value": "xs", "label": "Extra Small" }
          ],
          "default": "md"
        },
        {
          "type": "checkbox",
          "id": "span_justify",
          "label": "Justify Text",
          "default": false
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Text Color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Background Color",
          "default": "#000000"
        },
        {
          "type": "font_picker",
          "id": "button_font",
          "label": "Font",
          "default": "helvetica_n4"
        },
        {
          "type": "select",
          "id": "button_weight",
          "label": "Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "600"
        },
        {
          "type": "select",
          "id": "button_size",
          "label": "Font Size",
          "options": [
            { "value": "2xl", "label": "2X Large" },
            { "value": "xl", "label": "Extra Large" },
            { "value": "lg", "label": "Large" },
            { "value": "md", "label": "Medium" },
            { "value": "sm", "label": "Small" },
            { "value": "xs", "label": "Extra Small" }
          ],
          "default": "md"
        },
        {
          "type": "range",
          "id": "button_radius",
          "min": 0,
          "max": 40,
          "step": 2,
          "unit": "px",
          "label": "Border Radius",
          "default": 4
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Banner",
      "category": "Custom Content",
      "blocks": [
        { "type": "title" },
        { "type": "title" },
        { "type": "span" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}

<div id="CustomBanner-{{ section.id }}"
  class="custom-banner custom-banner--{{ section.settings.section_height }} custom-banner--content-align-{{ section.settings.content_justify }}"
  data-section-id="{{ section.id }}"
>
  <div class="custom-banner__background">
    {% if section.settings.background_video_desktop != blank or section.settings.background_video_mobile != blank or section.settings.background_video_url_desktop != blank or section.settings.background_video_url_mobile != blank %}
      <div class="custom-banner__video-container">
        {% if section.settings.background_video_desktop != blank %}
          <video 
            class="custom-banner__video custom-banner__video-desktop" 
            autoplay 
            playsinline
            muted
            preload="auto"
          >
            <source src="{{ section.settings.background_video_desktop.url }}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        {% elsif section.settings.background_video_url_desktop != blank %}
          <video 
            class="custom-banner__video custom-banner__video-desktop" 
            autoplay 
            playsinline
            muted
            preload="auto"
          >
            <source src="{{ section.settings.background_video_url_desktop }}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        {% endif %}
        
        {% if section.settings.background_video_mobile != blank %}
            <video 
              class="custom-banner__video custom-banner__video-mobile" 
              autoplay 
              playsinline
            muted
              preload="auto"
            >
            <source src="{{ section.settings.background_video_mobile.url }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
        {% elsif section.settings.background_video_url_mobile != blank %}
            <video 
            class="custom-banner__video custom-banner__video-mobile" 
              autoplay 
              playsinline
            muted
              preload="auto"
            >
            <source src="{{ section.settings.background_video_url_mobile }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
        {% endif %}
      </div>
    {% else %}
      <div class="custom-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}
    
    <div class="custom-banner__overlay"></div>
  </div>
  
  <div class="custom-banner__content-container custom-banner__content--{{ section.settings.content_position_desktop | replace: '_', '-' }} custom-banner__content--mobile-{{ section.settings.content_position_mobile | replace: '_', '-' }}">
    <div class="custom-banner__content">
      <div class="custom-banner__text-content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'title' %}
              {% assign title_tag = 'h2' %}
              {% if block.settings.title_size == 'h1' %}
                {% assign title_tag = 'h1' %}
              {% elsif block.settings.title_size == 'h2' %}
                {% assign title_tag = 'h2' %}
              {% elsif block.settings.title_size == 'h3' %}
                {% assign title_tag = 'h3' %}
              {% elsif block.settings.title_size == 'h4' %}
                {% assign title_tag = 'h4' %}
              {% elsif block.settings.title_size == 'h5' %}
                {% assign title_tag = 'h5' %}
              {% elsif block.settings.title_size == 'h6' %}
                {% assign title_tag = 'h6' %}
              {% else %}
                {% assign title_tag = 'div' %}
              {% endif %}
              <{{ title_tag }} 
                class="custom-banner__title custom-banner__title--{{ block.settings.title_size }}"
                style="{% if block.settings.title_color contains 'gradient' %}background: {{ block.settings.title_color }};-webkit-background-clip: text;-webkit-text-fill-color: transparent;{% else %}color: {{ block.settings.title_color }};{% endif %}
                       font-family: {{ block.settings.title_font.family | escape }}, {{ block.settings.title_font.fallback_families | escape }};
                       font-weight: {{ block.settings.title_weight }};"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.title_text }}
              </{{ title_tag }}>
            {% when 'span' %}
              <div class="custom-banner__paragraph custom-banner__paragraph--{{ block.settings.span_size }}"
                style="color: {{ block.settings.span_color }};
                       font-family: {{ block.settings.span_font.family | escape }}, {{ block.settings.span_font.fallback_families | escape }};
                       font-weight: {{ block.settings.span_weight }};"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.span_text }}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      <div class="custom-banner__button-container">
        {% for block in section.blocks %}
          {% if block.type == 'button' %}
            <a href="{{ block.settings.button_link }}" 
              class="custom-banner__button custom-banner__button--{{ block.settings.button_size }}"
              style="color: {{ block.settings.button_text_color }};
                     background-color: {{ block.settings.button_bg_color }};
                     font-family: {{ block.settings.button_font.family | escape }}, {{ block.settings.button_font.fallback_families | escape }};
                     font-weight: {{ block.settings.button_weight }};
                     border-radius: {{ block.settings.button_radius }}px;"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="custom-banner__controls">
      <button class="custom-banner__pause-btn" aria-label="Pause video" style="background: {{ section.settings.control_btn_bg_color }}; color: {{ section.settings.control_btn_icon_color }};">
        <!-- Pause icon SVG (default state) -->
        <svg class="custom-banner__pause-icon" width="20" height="20" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(0.000000,100.000000) scale(0.100000,-0.100000)" fill="currentColor" stroke="none">
            <path d="M240 500 l0 -340 100 0 100 0 0 340 0 340 -100 0 -100 0 0 -340z m160 0 l0 -300 -60 0 -60 0 0 300 0 300 60 0 60 0 0 -300z"/>
            <path d="M560 500 l0 -340 100 0 100 0 0 340 0 340 -100 0 -100 0 0 -340z m160 0 l0 -300 -60 0 -60 0 0 300 0 300 60 0 60 0 0 -300z"/>
          </g>
        </svg>
        <!-- Play icon SVG (hidden by default) -->
        <svg class="custom-banner__play-icon" width="20" height="20" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
          <g transform="translate(0.000000,100.000000) scale(0.100000,-0.100000)" fill="currentColor" stroke="none">
            <path d="M200 500 c0 -214 2 -390 5 -390 11 0 655 383 655 390 0 7 -644 390 -655 390 -3 0 -5 -175 -5 -390z m318 161 c144 -84 262 -157 262 -161 0 -6 -501 -306 -532 -318 -4 -2 -8 141 -8 318 0 177 4 320 8 318 5 -1 127 -72 270 -157z"/>
          </g>
        </svg>
        <span class="custom-banner__btn-text">Pause</span>
      </button>
      <button class="custom-banner__unmute-btn" aria-label="Unmute video" style="background: {{ section.settings.control_btn_bg_color }}; color: {{ section.settings.control_btn_icon_color }};">
        <!-- Unmute icon SVG (default state) -->
        <svg class="custom-banner__unmute-icon" width="20" height="20" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(0.000000,100.000000) scale(0.100000,-0.100000)" fill="currentColor" stroke="none">
            <path d="M325 810 l-131 -130 -77 0 c-115 0 -117 -4 -117 -180 0 -176 2 -180 117 -180 l77 0 131 -130 c138 -136 158 -147 195 -110 19 19 20 33 20 418 0 344 -2 401 -16 420 -32 45 -58 31 -199 -108z m173 -305 c1 -257 -1 -392 -8 -399 -7 -7 -54 33 -150 129 l-140 140 0 125 0 125 137 137 c76 76 142 137 148 135 6 -2 11 -142 13 -392z m-338 -5 l0 -141 -57 3 -58 3 -3 124 c-1 69 0 131 2 138 4 9 24 13 61 13 l55 0 0 -140z"/>
            <path d="M752 846 c2 -8 26 -30 53 -49 60 -40 120 -122 140 -191 44 -149 -14 -317 -140 -403 -54 -37 -69 -63 -37 -63 26 0 89 47 139 105 64 72 87 140 87 255 0 75 -5 107 -22 151 -25 62 -84 136 -146 181 -42 30 -80 37 -74 14z"/>
            <path d="M683 744 c-3 -9 3 -21 18 -32 146 -99 157 -309 21 -407 -40 -29 -50 -54 -25 -62 7 -3 40 22 72 54 46 46 63 72 75 113 35 116 12 206 -74 292 -61 61 -77 68 -87 42z"/>
            <path d="M595 620 c-8 -13 3 -30 20 -30 22 0 65 -59 65 -90 0 -30 -43 -90 -65 -90 -14 0 -27 -25 -18 -34 26 -26 97 27 114 85 9 30 9 48 0 78 -18 61 -95 115 -116 81z"/>
          </g>
        </svg>
        <!-- Mute icon SVG (hidden by default) -->
        <svg class="custom-banner__mute-icon" width="20" height="20" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
          <g transform="translate(0.000000,100.000000) scale(0.100000,-0.100000)" fill="currentColor" stroke="none">
            <path d="M325 810 l-131 -130 -77 0 c-115 0 -117 -4 -117 -180 0 -176 2 -180 117 -180 l77 0 131 -130 c138 -136 158 -147 195 -110 19 19 20 33 20 418 0 344 -2 401 -16 420 -32 45 -58 31 -199 -108z m173 -305 c1 -257 -1 -392 -8 -399 -7 -7 -54 33 -150 129 l-140 140 0 125 0 125 137 137 c76 76 142 137 148 135 6 -2 11 -142 13 -392z m-338 -5 l0 -141 -57 3 -58 3 -3 124 c-1 69 0 131 2 138 4 9 24 13 61 13 l55 0 0 -140z"/>
            <path d="M624 609 c-3 -6 15 -33 42 -60 l48 -49 -49 -50 c-38 -39 -47 -52 -37 -62 10 -10 23 -1 62 37 l50 49 50 -49 c39 -38 52 -47 62 -37 10 10 1 23 -37 62 l-49 50 49 50 c38 39 47 52 37 62 -10 10 -23 1 -62 -37 l-50 -49 -48 47 c-51 50 -57 53 -68 36z"/>
          </g>
        </svg>
        <span class="custom-banner__btn-text">Unmute</span>
      </button>
  </div>
</div>

<style>
  .custom-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    /* No border radius */
  }
  
  /* Heights */
  .custom-banner--small {
    height: 400px;
  }
  
  .custom-banner--medium {
    height: 600px;
  }
  
  .custom-banner--big {
    height: 800px;
  }
  
  .custom-banner--vh {
    height: calc(100vh - 38px);
  }
  
  .custom-banner--adapt {
    min-height: 400px;
  }
  
  /* Background */
  .custom-banner__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  .custom-banner__image,
  .custom-banner__video-container,
  .custom-banner__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .custom-banner__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  .custom-banner__image-desktop {
    display: block;
  }
  
  .custom-banner__image-mobile,
  .custom-banner__video-mobile {
    display: none;
  }
  
  .custom-banner__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  .custom-banner__placeholder {
    background-color: #f8f8f8;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .custom-banner__placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.2;
  }
  
  .custom-banner__iframe-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  
  .custom-banner__iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .custom-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.1);
  }
  
  /* Content */
  .custom-banner__content-container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1440px;
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    padding: 150px 0px;
    height: 100%;
  }

  @media screen and (max-width: 1440px) {
    .custom-banner__content-container {
      padding: 150px 50px;
    }
  }
  
  .custom-banner__content {
    display: flex;
    flex-direction: column;
    width: auto;
    max-width: 600px;
    gap: 24px;
  }
  /* Content position classes (desktop) */
  .custom-banner__content--top-left { justify-content: flex-start; align-items: flex-start; }
  .custom-banner__content--top-center { justify-content: flex-start; align-items: center; }
  .custom-banner__content--top-right { justify-content: flex-start; align-items: flex-end; }
  .custom-banner__content--middle-left { justify-content: center; align-items: flex-start; }
  .custom-banner__content--middle-center { justify-content: center; align-items: center; }
  .custom-banner__content--middle-right { justify-content: center; align-items: flex-end; }
  .custom-banner__content--bottom-left { justify-content: flex-end; align-items: flex-start; }
  .custom-banner__content--bottom-center { justify-content: flex-end; align-items: center; }
  .custom-banner__content--bottom-right { justify-content: flex-end; align-items: flex-end; }
  /* Mobile content position classes */
  @media (max-width: 749px) {
    .custom-banner__content--mobile-top-left { justify-content: flex-start; align-items: flex-start; }
    .custom-banner__content--mobile-top-center { justify-content: flex-start; align-items: center; }
    .custom-banner__content--mobile-top-right { justify-content: flex-start; align-items: flex-end; }
    .custom-banner__content--mobile-middle-left { justify-content: center; align-items: flex-start; }
    .custom-banner__content--mobile-middle-center { justify-content: center; align-items: center; }
    .custom-banner__content--mobile-middle-right { justify-content: center; align-items: flex-end; }
    .custom-banner__content--mobile-bottom-left { justify-content: flex-end; align-items: flex-start; }
    .custom-banner__content--mobile-bottom-center { justify-content: flex-end; align-items: center; }
    .custom-banner__content--mobile-bottom-right { justify-content: flex-end; align-items: flex-end; }
  }
  /* Text alignment for text and button containers */
  .custom-banner--content-align-left .custom-banner__text-content,
