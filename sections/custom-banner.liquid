{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "big",
          "label": "Big"
        },
        {
          "value": "vh",
          "label": "Viewport Height (100vh)"
        },
        {
          "value": "adapt",
          "label": "Adapt to Content"
        }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background Type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Desktop)",
      "info": "Recommended size: 1800 x 1000px"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image (Mobile)",
      "info": "Recommended size: 800 x 1200px. If not selected, desktop image will be used."
    },
    {
      "type": "url",
      "id": "background_video_url",
      "label": "Video URL (Desktop)",
      "info": "Enter direct video URL (MP4 recommended for best compatibility)"
    },
    {
      "type": "url",
      "id": "background_video_url_mobile",
      "label": "Video URL (Mobile)",
      "info": "If not provided, desktop video will be used on mobile"
    },
    {
      "type": "video_url",
      "id": "background_video",
      "label": "YouTube/Vimeo Video",
      "accept": ["youtube", "vimeo"],
      "info": "Add a YouTube or Vimeo URL",
      "placeholder": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop Video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute Video",
      "default": true
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "select",
      "id": "content_position_desktop",
      "label": "Content Position (Desktop)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "label": "Content Position (Mobile)",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "top"
    },
    {
      "type": "range",
      "id": "space_between_desktop",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Space Between Elements (Desktop)",
      "default": 30
    },
    {
      "type": "range",
      "id": "space_between_mobile",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Space Between Elements (Mobile)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Animation Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable GSAP Animations",
      "default": true
    },
    {
      "type": "select",
      "id": "animation_type",
      "label": "Animation Type",
      "options": [
        {
          "value": "fade",
          "label": "Fade In"
        },
        {
          "value": "slide_up",
          "label": "Slide Up"
        },
        {
          "value": "slide_left",
          "label": "Slide from Left"
        },
        {
          "value": "slide_right",
          "label": "Slide from Right"
        },
        {
          "value": "scale",
          "label": "Scale In"
        }
      ],
      "default": "slide_up"
    },
    {
      "type": "select",
      "id": "animation_trigger",
      "label": "Animation Trigger",
      "options": [
        {
          "value": "onload",
          "label": "On Page Load"
        },
        {
          "value": "scroll",
          "label": "On Scroll"
        }
      ],
      "default": "onload"
    },
    {
      "type": "range",
      "id": "animation_delay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "unit": "s",
      "label": "Animation Delay Between Elements",
      "default": 0.2
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title_text",
          "label": "Title Text",
          "default": "Your Title Here"
        },
        {
          "type": "color_background",
          "id": "title_color",
          "label": "Title Color",
          "default": "#000000"
        },
        {
          "type": "font_picker",
          "id": "title_font",
          "label": "Title Font",
          "default": "helvetica_n4"
        },
        {
          "type": "select",
          "id": "title_weight",
          "label": "Font Weight",
          "options": [
            {
              "value": "400",
              "label": "Regular"
            },
            {
              "value": "500",
              "label": "Medium"
            },
            {
              "value": "600",
              "label": "Semibold"
            },
            {
              "value": "700",
              "label": "Bold"
            }
          ],
          "default": "700"
        },
        {
          "type": "select",
          "id": "title_size",
          "label": "Font Size",
          "options": [
            {
              "value": "ultra",
              "label": "Ultra (Largest)"
            },
            {
              "value": "mega",
              "label": "Mega"
            },
            {
              "value": "hero",
              "label": "Hero"
            },
            {
              "value": "display",
              "label": "Display"
            },
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h6",
              "label": "H6 (Smallest)"
            }
          ],
          "default": "h2"
        }
      ]
    },
    {
