{{ 'section-collapsible-image.css' | asset_url | stylesheet_tag }}

<div class="collapsible-image-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.background-color }}">
  <div class="page-width">
    <div class="collapsible-image-container{% if section.settings.layout == 'image_first' %} image-first{% else %} image-second{% endif %}">
      
      <!-- Image Section -->
      <div class="collapsible-image-media">
        {%- if section.settings.image != blank -%}
          <div class="media media--square">
            <img
              srcset="{%- if section.settings.image.width >= 375 -%}{{ section.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
                      {%- if section.settings.image.width >= 550 -%}{{ section.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
                      {%- if section.settings.image.width >= 750 -%}{{ section.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
                      {{ section.settings.image | image_url }} {{ section.settings.image.width }}w"
              src="{{ section.settings.image | image_url: width: 550 }}"
              sizes="(min-width: 990px) 50vw, 100vw"
              alt="{{ section.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          </div>
        {%- else -%}
          <div class="media media--square media--placeholder">
            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <!-- Content Section -->
      <div class="collapsible-image-content">
        
        {%- if section.settings.heading != blank -%}
          <h2 class="collapsible-image-heading h2" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="collapsible-image-text rte" style="color: {{ section.settings.text_color }};">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="collapsible-tabs">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'collapsible_tab' -%}
                  <details class="collapsible-tab" {{ block.shopify_attributes }} style="background-color: {{ block.settings.background-color }};">
                    <summary class="collapsible-tab-heading">
                      <div class="collapsible-tab-icon" style="color: {{ block.settings.icon_color }};">
                        {%- if block.settings.icon != 'none' -%}
                          {% render 'icon-accordion', icon: block.settings.icon %}
                        {%- endif -%}
                      </div>
                      <h3 class="collapsible-tab-title" style="color: {{ block.settings.heading_color }};">
                        {{ block.settings.heading | default: 'Tab heading' }}
                      </h3>
                      <div class="collapsible-tab-toggle">
                        <svg class="icon icon-plus" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path style="color: {{ block.settings.icon_toggle_color }};" d="M8 1V15M1 8H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <svg class="icon icon-minus" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path style="color: {{ block.settings.icon_toggle_color }};" d="M1 8H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </div>
                    </summary>
                    <div class="collapsible-tab-content rte" style="color: {{ block.settings.content_color }};">
                      {{ block.settings.content }}
                    </div>
                  </details>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

<style>
  .collapsible-image-section {
    padding: 5rem 0;
  }

  .collapsible-image-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .collapsible-image-container.image-second {
    grid-template-columns: 1fr 1fr;
  }

  .collapsible-image-container.image-second .collapsible-image-media {
    order: 2;
  }

  .collapsible-image-container.image-second .collapsible-image-content {
    order: 1;
  }

  .media--square {
    aspect-ratio: 1;
    border-radius: 1rem;
    overflow: hidden;
  }

  .media--square img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media--placeholder {
    background-color: rgba(18, 18, 18, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media--placeholder svg {
    width: 4rem;
    height: 4rem;
    opacity: 0.3;
  }

  .collapsible-image-heading {
    margin: 0 0 1rem 0;
    font-size: 2.4rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .collapsible-image-text {
    margin: 0 0 2rem 0;
    font-size: 1.6rem;
    line-height: 1.5;
  }

  .collapsible-tabs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .collapsible-tab {
    border: 1px solid rgba(18, 18, 18, 0.08);
    border-radius: 0.8rem;
    overflow: hidden;
  }

  .collapsible-tab-heading {
    display: flex;
    align-items: center;
    padding: 1.5rem;
    cursor: pointer;
    gap: 1rem;
    background: transparent;
    transition: background-color 0.2s ease;
    list-style: none;
  }

  .collapsible-tab-heading::-webkit-details-marker {
    display: none;
  }

  .collapsible-tab-heading:hover {
    background-color: rgba(18, 18, 18, 0.02);
  }

  .collapsible-tab-icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collapsible-tab-icon svg {
    width: 100%;
    height: 100%;
  }

  .collapsible-tab-title {
    flex-grow: 1;
    font-size: 1.6rem;
    font-weight: 500;
    margin: 0;
    text-align: left;
  }

  .collapsible-tab-toggle {
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    position: relative;
  }

  .collapsible-tab-toggle .icon-plus {
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  .collapsible-tab-toggle .icon-minus {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .collapsible-tab[open] .collapsible-tab-toggle .icon-plus {
    opacity: 0;
  }

  .collapsible-tab[open] .collapsible-tab-toggle .icon-minus {
    opacity: 1;
  }

  .collapsible-tab-content {
    padding: 1.5rem 1.5rem 1.5rem 4.5rem;
    font-size: 1.4rem;
    line-height: 1.5;
  }

  /* Mobile Styles */
  @media screen and (max-width: 749px) {
    .collapsible-image-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .collapsible-image-container.image-second .collapsible-image-media {
      order: 1;
    }

    .collapsible-image-container.image-second .collapsible-image-content {
      order: 2;
    }

    .collapsible-image-heading {
      font-size: 3rem;
    }

    .collapsible-tab-heading {
      padding: 1.2rem;
    }

    .collapsible-tab-content {
      padding: 1.2rem 1.2rem 1.2rem 3.7rem;
    }
  }

  /* Section padding custom property support */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

