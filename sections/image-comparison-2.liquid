<style>
/* Image Comparison Section */
.image-comparison-section {
  padding: 36px 0;
}

.image-comparison-heading-container {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.image-comparison-heading {
  text-align: center;
  margin: 0 0 4rem 0;
  font-size: 5.2rem;
  font-weight: 300;
  line-height: normal;
  letter-spacing: -1px;
}

.image-comparison-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  max-width: 120rem;
  margin: 0 auto;
}

/* Image Comparator */
.image-comparator-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
}

.image-comparator {
  position: relative;
  max-width: 50rem;
  width: 100%;
  overflow: hidden;
  user-select: none;
  -webkit-user-select: none;
}

/* Image Format Variations */
.image-comparator--circle {
  aspect-ratio: 1;
  border-radius: 50%;
}

.image-comparator--square {
  aspect-ratio: 1;
  border-radius: 1rem;
}

.image-comparator--rectangle {
  aspect-ratio: 4/5;
  border-radius: 1rem;
}

.image-comparator--wide-rectangle {
  aspect-ratio: 16/9;
  border-radius: 1rem;
}

/* Comparison Images */
.comparison-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.comparison-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.comparison-image--before {
  z-index: 1;
}

.comparison-image--after {
  z-index: 2;
  width: 50%;
}

/* Circle and Square specific clipping */
.image-comparator--circle .comparison-image--after,
.image-comparator--square .comparison-image--after {
  width: 100%;
  clip-path: inset(0 50% 0 0);
}

/* Placeholder */
.comparison-placeholder {
  width: 100%;
  height: 100%;
  background-color: rgba(18, 18, 18, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
}

.comparison-placeholder svg {
  width: 4rem;
  height: 4rem;
  opacity: 0.3;
}

/* Slider Control */
.comparison-slider {
  position: absolute;
  top: 0;
  left: 50%;
  width: 0.4rem;
  height: 100%;
  background: white;
  cursor: ew-resize;
  z-index: 10;
  transform: translateX(-50%);
  transition: opacity 0.2s ease;
}

.comparison-slider::before {
  content: '';
  position: absolute;
  top: 0;
  left: -1rem;
  width: 2.4rem;
  height: 100%;
  background: transparent;
}

.comparison-slider-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 4rem;
  height: 4rem;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0.4rem 1.2rem rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.comparison-slider-button:hover {
  transform: translate(-50%, -50%) scale(1.1);
  box-shadow: 0 0.6rem 2rem rgba(0, 0, 0, 0.2);
}

.comparison-slider-button svg {
  width: 1.6rem;
  height: 1.6rem;
  color: #666;
}

.comparison-slider-button svg:first-child {
  margin-right: -0.4rem;
}

.comparison-slider-button svg:last-child {
  margin-left: -0.4rem;
}

/* Features Grid */
.image-comparison-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
}

.feature-item {
  text-align: center;
  max-width: 30rem;
  margin: 0 auto;
}

.feature-icon {
  width: 5rem;
  height: 5rem;
  margin: 0 auto 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon svg {
  width: 5rem;
  height: 5rem;
  fill: currentColor;
}

.feature-icon span {
  width: 5rem;
  height: 5rem;
}

.feature-title {
  font-size: 2.4rem;
  font-weight: 400;
  margin: 0 0 1rem 0;
  line-height: normal;
  letter-spacing: -0.5px;
}

.feature-text {
  font-size: 1.6rem;
  line-height: 1.2;
  letter-spacing: -0.5px;
  margin: 0;
}

.feature-text p {
  margin: 0 0 1rem 0;
}

.feature-text p:last-child {
  margin-bottom: 0;
}

/* Responsive Design */
@media screen and (max-width: 1199px) {
  .image-comparison-container {
    gap: 4rem;
  }
  
  .image-comparison-heading {
    font-size: 2.8rem;
  }
}

@media screen and (max-width: 989px) {
  .image-comparison-container {
    gap: 3rem;
  }
  
  .image-comparison-heading {
    font-size: 2.4rem;
    margin-bottom: 3rem;
  }
  
  .image-comparator {
    max-width: 40rem;
  }
}

@media screen and (max-width: 749px) {
  .image-comparison-section {
    padding: 3rem 0;
  }

  .image-comparison-container {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  .image-comparison-heading {
    font-size: 4rem;
    margin-bottom: 2.5rem;
  }

  .image-comparator {
    max-width: 35rem;
    order: 1;
  }

  .image-comparison-features {
    order: 2;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .feature-item {
    max-width: none;
  }

  .feature-icon {
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1rem;
  }

  .feature-icon svg {
    width: 3.5rem;
    height: 3.5rem;
  }

  .feature-title {
    font-size: 2.2rem;
    margin-bottom: 0;
  }

  .feature-text {
    font-size: 1.6rem;
    display: flex;
    justify-content: center;
    align-items: center;
    p {
      width:80%;
    }
  }

}

@media screen and (max-width: 479px) {
  .image-comparison-container {
    gap: 4rem;
  }
  
  .image-comparison-heading {
    font-size: 4rem;
    margin-bottom: 2rem;
  }

  .image-comparator {
    max-width: 36rem;
  }

  .image-comparison-features {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .comparison-slider-button {
    width: 3.2rem;
    height: 3.2rem;
  }

  .comparison-slider-button svg {
    width: 1.4rem;
    height: 1.4rem;
  }
}

/* Touch device optimizations */
@media (hover: none) and (pointer: coarse) {
  .comparison-slider-button {
    width: 4.8rem;
    height: 4.8rem;
  }
  
  .comparison-slider::before {
    width: 3.2rem;
    left: -1.4rem;
  }
}

/* High contrast mode */
@media (prefers-contrast: high) {
  .comparison-slider {
    background: #000;
  }
  
  .comparison-slider-button {
    border: 2px solid #000;
  }
  
  .feature-icon {
    background: rgba(255, 255, 255, 1);
    border: 1px solid rgba(0, 0, 0, 0.2);
  }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .comparison-slider,
  .comparison-slider-button {
    transition: none;
  }
}

/* Section padding custom properties */
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}

@media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}
</style>