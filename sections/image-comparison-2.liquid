

<div class="image-comparison-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <div class="image-comparison-heading-container {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
        style="--animation-order: 1;"
      {% endif %}
      >
        <h2 class="image-comparison-heading h1" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    <div class="image-comparison-container">
      
      <!-- Image Comparator -->
      <div class="image-comparator-wrapper {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
        style="--animation-order: 2;"
      {% endif %}
      >
        <div class="image-comparator image-comparator--{{ section.settings.image_format }}" id="comparator-{{ section.id }}">
          
          <!-- Before Image (Left/Top) -->
          <div class="comparison-image comparison-image--before">
            {%- if section.settings.image_before != blank -%}
              <img
                src="{{ section.settings.image_before | image_url: width: 800 }}"
                srcset="{{ section.settings.image_before | image_url: width: 400 }} 400w,
                        {{ section.settings.image_before | image_url: width: 600 }} 600w,
                        {{ section.settings.image_before | image_url: width: 800 }} 800w"
                sizes="(min-width: 990px) 50vw, 90vw"
                alt="{{ section.settings.image_before.alt | escape }}"
                loading="lazy"
                width="{{ section.settings.image_before.width }}"
                height="{{ section.settings.image_before.height }}"
              >
            {%- else -%}
              <div class="comparison-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <!-- After Image (Right/Bottom) -->
          <div class="comparison-image comparison-image--after">
            {%- if section.settings.image_after != blank -%}
              <img
                src="{{ section.settings.image_after | image_url: width: 800 }}"
                srcset="{{ section.settings.image_after | image_url: width: 400 }} 400w,
                        {{ section.settings.image_after | image_url: width: 600 }} 600w,
                        {{ section.settings.image_after | image_url: width: 800 }} 800w"
                sizes="(min-width: 990px) 50vw, 90vw"
                alt="{{ section.settings.image_after.alt | escape }}"
                loading="lazy"
                width="{{ section.settings.image_after.width }}"
                height="{{ section.settings.image_after.height }}"
              >
            {%- else -%}
              <div class="comparison-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <!-- Slider Control -->
          <div class="comparison-slider" id="slider-{{ section.id }}">
            <div class="comparison-slider-button">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

        </div>
      </div>

      <!-- Features Grid -->
      {%- if section.blocks.size > 0 -%}
        <div class="image-comparison-features">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'feature' -%}
                <div class="feature-item {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" 
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index | plus: 2 }};"
                {% endif %}
                >
                  {%- if block.settings.icon != 'none' -%}
                    <div class="feature-icon" style="color: {{ block.settings.icon_color }};">
                      {% render 'icon-accordion', icon: block.settings.icon %}
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.title != blank -%}
                    <h3 class="feature-title" style="color: {{ block.settings.title_color }};">
                      {{ block.settings.title }}
                    </h3>
                  {%- endif -%}
                  
                  {%- if block.settings.text != blank -%}
                    <div class="feature-text rte" style="color: {{ block.settings.text_color }};">
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const comparator = document.getElementById('comparator-{{ section.id }}');
    const slider = document.getElementById('slider-{{ section.id }}');
    
    if (!comparator || !slider) return;
    
    const afterImage = comparator.querySelector('.comparison-image--after');
    let isResizing = false;
    
    function updateComparison(percentage) {
      percentage = Math.max(0, Math.min(100, percentage));
      
      if (comparator.classList.contains('image-comparator--circle') || 
          comparator.classList.contains('image-comparator--square')) {
        // For circle and square, use clip-path
        afterImage.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
        slider.style.left = `${percentage}%`;
      } else {
        // For rectangles, use width
        afterImage.style.width = `${percentage}%`;
        slider.style.left = `${percentage}%`;
      }
    }
    
    function handleInteraction(clientX) {
      const rect = comparator.getBoundingClientRect();
      const percentage = ((clientX - rect.left) / rect.width) * 100;
      updateComparison(percentage);
    }
    
    // Mouse events
    slider.addEventListener('mousedown', function(e) {
      isResizing = true;
      document.body.style.cursor = 'ew-resize';
      e.preventDefault();
    });
    
    document.addEventListener('mousemove', function(e) {
      if (!isResizing) return;
      handleInteraction(e.clientX);
    });
    
    document.addEventListener('mouseup', function() {
      isResizing = false;
      document.body.style.cursor = '';
    });
    
    // Touch events
    slider.addEventListener('touchstart', function(e) {
      isResizing = true;
      e.preventDefault();
    });
    
    document.addEventListener('touchmove', function(e) {
      if (!isResizing) return;
      e.preventDefault();
      const touch = e.touches[0];
      handleInteraction(touch.clientX);
    });
    
    document.addEventListener('touchend', function() {
      isResizing = false;
    });
    
    // Click on comparator
    comparator.addEventListener('click', function(e) {
      if (e.target === slider || slider.contains(e.target)) return;
      handleInteraction(e.clientX);
    });
    
    // Initialize at 50%
    updateComparison(50);
  });
</script>

