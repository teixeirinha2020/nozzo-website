{% assign base_price = product.selected_or_first_available_variant.price %}
{% assign current_variant_id = product.selected_or_first_available_variant.id %}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<div class="buy-more-save-more" data-variant-id="{{ current_variant_id }}">
  {% if block.settings.mini_heading != blank %}
    <h3 class="mini-heading">
      {{ block.settings.mini_heading }}
    </h3>
  {% endif %}

  <!-- Subscription Toggle -->
  {% if block.settings.enable_subscriptions and product.selling_plan_groups.size > 0 %}
    <div class="purchase-options-toggle">
      <label class="toggle-option active" data-purchase-type="onetime">
        <input type="radio" name="purchase-type" value="onetime" checked>
        <span>{{ block.settings.onetime_text | default: 'One-time purchase' }}</span>
      </label>
      
      {% for group in product.selling_plan_groups %}
        <label class="toggle-option" data-purchase-type="subscription" data-group-id="{{ group.id }}">
          <input type="radio" name="purchase-type" value="subscription-{{ group.id }}">
          <span>{{ group.name }}</span>
        </label>
      {% endfor %}
    </div>
  {% endif %}

  <!-- One-time Purchase Options -->
  <div class="quantity-options" data-purchase-type="onetime">
    {% assign option_count = block.settings.number_of_options | default: 1 %}
    {% for discount in product.metafields.custom.discount.value %}
      {% assign option_count = forloop.index %}
    {% endfor %}
    {% for i in (1..option_count) %}
      {% assign title_setting = 'option_' | append: i | append: '_title' %}
      {% assign title_color_setting = 'option_' | append: i | append: '_title_color' %}
      {% assign price_color_setting = 'option_' | append: i | append: '_price_color' %}
      {% assign border_color_setting = 'option_' | append: i | append: '_border_color' %}
      {% assign badge_text_color_setting = 'option_' | append: i | append: '_badge_text_color' %}
      {% assign image_setting = 'option_' | append: i | append: '_image' %}
      {% assign j = i | minus: 1 %}
      {% assign discount_metafield = product.metafields.custom.discount.value[j] %} 
      {% assign discount_metafield_100 = discount_metafield | times: 100 %}
      {% assign quantity = i %}
      {% assign total_price = base_price | times: quantity %}
      {% assign multiplicator = quantity | times: 100.0 %}
      
      {% case quantity %}
        {% when 1 %}
          {% assign discounted_price = block.settings.price_1_unit %}
          {% if discounted_price <= 0 %}
            {% assign discounted_price = total_price | minus: discount_metafield_100 %}
          {% endif %}
          {% assign original_price = total_price %}
          {% assign discount_percentage = total_price | minus: discounted_price | times: 100.0 | divided_by: total_price | round %}
        {% when 2 %}
          {% assign discounted_price = block.settings.price_2_units %}
          {% if discounted_price <= 0 %}
            {% assign discounted_price = total_price | minus: discount_metafield_100 %}
          {% endif %}
          {% assign original_price = total_price %}
          {% assign discount_percentage = total_price | minus: discounted_price | times: 100.0 | divided_by: total_price | round %}
        {% when 3 %}
          {% assign discounted_price = block.settings.price_3_units %}
          {% if discounted_price <= 0 %}
            {% assign discounted_price = total_price | minus: discount_metafield_100 %}
          {% endif %}
          {% assign original_price = total_price %}
          {% assign discount_percentage = total_price | minus: discounted_price | times: 100.0 | divided_by: total_price | round %}
        {% when 4 %}
          {% assign discounted_price = block.settings.price_4_units %}
          {% if discounted_price <= 0 %}
            {% assign discounted_price = total_price | minus: discount_metafield_100 %}
          {% endif %}
          {% assign original_price = total_price %}
          {% assign discount_percentage = total_price | minus: discounted_price | times: 100.0 | divided_by: total_price | round %}
      {% endcase %}

      <label class="quantity-option{% if forloop.index == 2 %} most-popular{% endif %}">
        <input type="radio" name="quantity-choice" value="{{ quantity }}" {% if forloop.index == 2 %}checked{% endif %}>
        <div class="option-content" style="border-color: {{ block.settings[border_color_setting] }}">
          {% if forloop.index == 2 %}
            <div class="popular-badge">
              Mais Popular
            </div>
          {% endif %}

          {% if block.settings[image_setting] != blank %}
            <div class="option-image">
              <img src="{{ block.settings[image_setting] | img_url: width: 1080, height: 1080, crop: 'center' }}" 
                   alt="Option {{ i }}" 
                   width="40" 
                   height="40"
                   loading="lazy"
                   id="option-{{ i }}-image"
                   data-option-quantity="{{ quantity }}">
            </div>
          {% endif %}

          <div class="option-header">
            <div class="title-and-badge">
              {% if block.settings[title_setting] != blank %}
                <h4 style="color: {{ block.settings[title_color_setting] }}" id="option-{{ i }}-title" data-option-quantity="{{ quantity }}">
                  {{ block.settings[title_setting] }}
                </h4>
              {% endif %}
              {% if discount_percentage > 0 %}
                <div class="discount-badge-v2" style="background: {{ block.settings.discount_badge_bg_color }}; color: {{ block.settings[badge_text_color_setting] }}; {% if quantity == 1 %} display: none; {% endif %}">
                {% if quantity != 1 %}  
                €{{ discounted_price | divided_by: multiplicator | round: 2 }} por saco
                {% endif %}
                </div> 
              {% endif %}
            </div>
            <div class="savings">
              {% if discount_percentage > 0 %}
                <p>
                  Poupa {{ discount_percentage }}%
                 </p>
              {% endif %}
            </div>
          </div>

          <div class="price-info">
            <div class="price-amount" style="color: {{ block.settings[price_color_setting] }}">
              €{{ discounted_price | divided_by: 100.0 | round: 2 }}
            </div>
            {% if discount_percentage > 0 %}
              <s class="original-price">€{{ original_price | divided_by: 100.0 | round: 2 }}</s>
            {% endif %}
          </div>
        </div>
      </label>
    {% endfor %}
  </div>

  <!-- Subscription Options -->
  {% if block.settings.enable_subscriptions and product.selling_plan_groups.size > 0 %}
    {% for group in product.selling_plan_groups %}
      <div class="subscription-plans" data-group-id="{{ group.id }}" style="display: none;">
        {% for plan in group.selling_plans %}
          <label class="subscription-plan-option{% if forloop.first %} selected{% endif %}">
            <input type="radio" name="subscription-plan" value="{{ plan.id }}" data-plan-discount="{{ plan.price_adjustments[0].value }}" {% if forloop.first %}checked{% endif %}>
            <div class="plan-content">
              <div class="plan-header">
                {% assign j = forloop.index |  plus: 1 %}
                <h4 style="color: {{ block.settings.types_of_purchase_text_color }};">{{ plan.options[0].value }}</h4>
                {% if plan.description != blank %}
                  <p class="plan-description">{{ plan.description }}</p>
                {% endif %}
              </div>
            </div>
          </label>
        {% endfor %}
        
        <!-- Subscription Quantity Options -->
        <div class="subscription-quantity-options">
          {% comment %} Always show the first option (1 pack) {% endcomment %}
          <label class="subscription-quantity-option">
            <input type="radio" name="subscription-quantity" value="1" data-discount="0" checked>
            <div class="quantity-content">
              {% if block.settings.option_1_image != blank %}
                <div class="option-image">
                  <img src="{{ block.settings.option_1_image | img_url: width: 1080, height: 1080, crop: 'center' }}" 
                       alt="1 Pack" 
                       width="40" 
                       height="40"
                       loading="lazy">
                </div>
              {% endif %}
              
              <div class="option-header">
                <div class="title-and-badge">
                  {% if block.settings.option_1_title != blank %}
                    <h4 style="color: {{ block.settings.option_1_title_color }}">{{ block.settings.option_1_title }}</h4>
                  {% else %}
                    <h4>1 Pack</h4>
                  {% endif %}
                </div>
                <div class="savings">
                  <p class="subscription-savings" data-quantity="1" data-discount="0">
                    <!-- Savings percentage will be calculated by JavaScript -->
                  </p>
                </div>
              </div>
              
              <div class="price-info">
                <div class="subscription-price-amount" style="color: {{ block.settings.option_1_price_color }}" data-base-price="{{ base_price }}">
                  €{{ base_price | divided_by: 100.0 | round: 2 }}
                </div>
                <s class="subscription-original-price" data-quantity="1" data-base-price="{{ base_price }}">
                  <!-- Original price will be shown by JavaScript if there's a discount -->
                </s>
              </div>
            </div>
          </label>
          
          {% comment %} Show additional options only if subscription_discount metadata exists and is not blank/zero {% endcomment %}
          {% if product.metafields.custom.subscription_discount.value != blank and product.metafields.custom.subscription_discount.value.size > 0 %}
            {% for discount in product.metafields.custom.subscription_discount.value %}
              {% comment %} Only show if discount is greater than 0 {% endcomment %}
              {% if discount != blank and discount != 0 %}
                {% assign quantity = forloop.index | plus: 1 %}
                
                {% assign title_setting = 'option_' | append: quantity | append: '_title' %}
                {% assign title_color_setting = 'option_' | append: quantity | append: '_title_color' %}
                {% assign price_color_setting = 'option_' | append: quantity | append: '_price_color' %}
                {% assign image_setting = 'option_' | append: quantity | append: '_image' %}
                
                <label class="subscription-quantity-option{% if quantity == 2 %} most-popular{% endif %}">
                  <input type="radio" name="subscription-quantity" value="{{ quantity }}" data-discount="{{ discount }}">
                  <div class="quantity-content">
                    {% if forloop.index == 1 %}
                      <div class="popular-badge">
                        Mais Popular
                      </div>
                    {% endif %}
                    
                    {% if block.settings[image_setting] != blank %}
                      <div class="option-image">
                        <img src="{{ block.settings[image_setting] | img_url: width: 1080, height: 1080, crop: 'center' }}" 
                             alt="{{ quantity }} Packs" 
                             width="40" 
                             height="40"
                             loading="lazy">
                      </div>
                    {% endif %}
                    
                    <div class="option-header">
                      <div class="title-and-badge">
                        {% if block.settings[title_setting] != blank %}
                          <h4 style="color: {{ block.settings[title_color_setting] }}">{{ block.settings[title_setting] }}</h4>
                        {% else %}
                          <h4>{{ quantity }} Packs</h4>
                        {% endif %}
                        <div class="discount-badge-v2 subscription-badge" style="background: {{ block.settings.discount_badge_bg_color }}; color: {{ block.settings.option_2_badge_text_color }}" data-quantity="{{ quantity }}" data-discount="{{ discount }}">
                          <!-- Price per unit will be calculated by JavaScript -->
                        </div>
                      </div>
                      <div class="savings">
                        <p class="subscription-savings" data-quantity="{{ quantity }}" data-discount="{{ discount }}">
                          <!-- Savings percentage will be calculated by JavaScript -->
                        </p>
                      </div>
                    </div>
                    
                    <div class="price-info">
                      <div class="subscription-price-amount" style="color: {{ block.settings[price_color_setting] }}" data-quantity="{{ quantity }}" data-discount="{{ discount }}" data-base-price="{{ base_price }}">
                        <!-- Total price will be calculated by JavaScript -->
                      </div>
                      <s class="subscription-original-price" data-quantity="{{ quantity }}" data-base-price="{{ base_price }}">
                        <!-- Original price will be calculated by JavaScript -->
                      </s>
                    </div>
                  </div>
                </label>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
    {% endfor %}
  {% endif %}

  <button type="button" class="add-to-cart-btn2" style="background: {{ block.settings.add_to_cart_bg_color }}; color: {{ block.settings.add_to_cart_text_color }}">
    <span class="cart-icon">
      <svg version="1.1" xmlns="http://www.w3.org/2000/svg" x="0" y="0" viewBox="0 0 128 128" style="enable-background:new 0 0 128 128" xml:space="preserve"><path fill="currentColor" d="M45.3 81.2h78V43.7L35.9 25.4l-3.1-12.9-12.6-4.2c0-.2.1-.3.1-.5 0-4.3-3.5-7.8-7.8-7.8S4.7 3.5 4.7 7.8s3.5 7.8 7.8 7.8c1.8 0 3.4-.6 4.7-1.6l9.4 4.7L39 78l-12.5 9.4V103l5.7 7.1c-1.6 1.9-2.5 4.3-2.5 7 0 6 4.9 10.9 10.9 10.9s10.9-4.9 10.9-10.9-4.9-10.9-10.9-10.9c-.9 0-1.8.1-2.6.3l-2.1-3.4h65.6l3.6 6c-2.2 2-3.6 4.9-3.6 8.1 0 6 4.9 10.9 10.9 10.9s10.9-4.9 10.9-10.9-4.9-10.9-10.9-10.9h-.3l-1.3-3.1h12.5V97H32.8v-6.2l12.5-9.6zm0-6.3-4.6-21.4.6 3L59.8 58l3.8 17H45.3zm21.8 0-3.7-16.7 18.1 1.4 1.4 15.3H67.1zm18.8 0-1.4-15 17 1.3v13.7H85.9zm31.2-15.6v15.6h-12.5V61.5l12.5 1v-3.2l-12.5-1V44.4l12.5 2.4v12.5zM35.9 31.2l65.6 12.6V58l-17.3-1.4-1.5-16.4-3.1-.6 1.6 16.8-18.5-1.5-4.3-19.3-3.7-.7 4.4 19.7-18.5-1.5-4.7-21.9zm76.5 81.2c2.6 0 4.7 2.1 4.7 4.7s-2.1 4.7-4.7 4.7-4.7-2.1-4.7-4.7 2.1-4.7 4.7-4.7zm-71.8 0c2.6 0 4.7 2.1 4.7 4.7s-2.1 4.7-4.7 4.7-4.7-2.1-4.7-4.7 2.1-4.7 4.7-4.7z"/></svg>
    </span>
    <span class="button-text" 
          data-onetime-text="{{ block.settings.add_to_cart_text }}"
          data-subscription-text="{{ block.settings.subscription_button_text }}">
      {{ block.settings.add_to_cart_text }}
    </span>
  </button>
</div>

<style>
  .buy-more-save-more {
    font-family: 'Poppins', sans-serif;
    max-width: 100%;
    margin: 20px 0;
  }

  .mini-heading {
    text-align: left;
    margin-bottom: 20px;
    font-weight: 600;
    font-size: 1.1em;
    color: {{ block.settings.mini_heading_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Purchase Options Toggle */
  .purchase-options-toggle {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 12px;
    background: #fafafa;
  }

  .toggle-option {
    display: flex;
    align-items: center;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 6px;
    transition: all 0.2s ease;
    background: white;
    border: 1px solid transparent;
    color: {{ block.settings.types_of_purchase_text_color }};
  }

  .toggle-option:hover {
    background: #f0f0f0;
  }

  .toggle-option.active {
    background: {{ block.settings.types_of_purchase_background_color }};
    color: white;
    font-weight: 500;
  }

  .toggle-option input[type="radio"] {
    position: absolute;
    opacity: 0;
  }

  .toggle-option span {
    font-size: 14px;
    font-weight: 500;
  }

  /* Quantity Options */
  .quantity-options {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .quantity-option {
    cursor: pointer;
    position: relative;
    display: block;
  }

  .quantity-option input[type="radio"] {
    position: absolute;
    opacity: 0;
  }

  .option-content {
    border: 1.5px solid #F01C7C;
    border-radius: 8px;
    padding: 12px 10px;
    position: relative;
    background: white;
    transition: all 0.2s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .option-image {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgb(182, 182, 182);
    transition: all 0.2s ease;
    z-index: 1;
  }

  .option-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .quantity-option input[type="radio"]:checked + .option-content .option-image {
    border-color: #F01C7C;
    border-width: 3px;
  }

  .quantity-option input[type="radio"]:checked + .option-content {
    border-width: 2px;
  }

  .option-header {
    display: flex !important;
    flex-direction: column;
    align-items: left;
    padding-left: 60px;
  }

  .savings p {
    margin: 0;
    font-size: 14px;
    font-weight: 400 !important;
  }

  .title-and-badge {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  @media screen and (max-width: 360px) {
    .title-and-badge {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
    }
  }

  .title-and-badge h4 {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    display: block;
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .discount-badge-v2 {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 400;
    background: #000000;
    color: white;
  }

  .price-info {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .price-amount {
    font-weight: 500;
    font-size: 16px;
    line-height: 1.2;
  }

  .original-price {
    font-size: 15px;
    color: #9CA3AF;
    text-decoration: line-through;
    line-height: normal;
    font-weight: 300;
  }

  /* Subscription Plans */
  .subscription-plans {
    margin-bottom: 20px;
  }

  .subscription-plan-option {
    cursor: pointer;
    position: relative;
    display: block;
    margin-bottom: 12px;
  }

  .subscription-plan-option input[type="radio"] {
    position: absolute;
    opacity: 0;
  }

  .plan-content {
    border: 1.5px solid #e5e5e5;
    border-radius: 8px;
    padding: 16px;
    background: white;
    transition: all 0.2s ease;
  }

  .subscription-plan-option input[type="radio"]:checked + .plan-content {
    border-color: #F01C7C;
    border-width: 2px;
  }

  .plan-header h4 {
    margin: 0;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: -0.5px;
    color: #000000;
  }

  .plan-description {
    margin: 0;
    font-size: 13px;
    color: #666;
  }

  /* Subscription Quantity Options */
  .subscription-quantity-options {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #e5e5e5;
  }

  .subscription-quantity-option {
    cursor: pointer;
    position: relative;
    display: block;
    margin-bottom: 12px;
  }

  .subscription-quantity-option input[type="radio"] {
    position: absolute;
    opacity: 0;
  }

  .subscription-quantity-option .quantity-content {
    border: 1.5px solid #F01C7C;
    border-radius: 8px;
    padding: 12px 10px;
    position: relative;
    background: white;
    transition: all 0.2s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .subscription-quantity-option input[type="radio"]:checked + .quantity-content {
    border-width: 2px;
  }

  .subscription-quantity-option .option-image {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgb(182, 182, 182);
    transition: all 0.2s ease;
    z-index: 1;
  }

  .subscription-quantity-option .option-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .subscription-quantity-option input[type="radio"]:checked + .quantity-content .option-image {
    border-color: #F01C7C;
    border-width: 3px;
  }

  .subscription-quantity-option .option-header {
    display: flex !important;
    flex-direction: column;
    align-items: left;
    padding-left: 60px;
  }

  .subscription-quantity-option .title-and-badge {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .subscription-quantity-option .title-and-badge h4 {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    display: block;
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .subscription-quantity-option .savings p {
    margin: 0;
    font-size: 14px;
    font-weight: 400 !important;
  }

  .subscription-quantity-option .price-info {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .subscription-quantity-option .price-amount,
  .subscription-price-amount {
    font-weight: 500;
    font-size: 16px;
    line-height: 1.2;
  }

  .subscription-original-price {
    font-size: 15px;
    color: #9CA3AF;
    text-decoration: line-through;
    line-height: normal;
    font-weight: 300;
  }

  /* Add to Cart Button */
  .add-to-cart-btn2 {
    width: 100%;
    border: none;
    padding: 16px;
    border-radius: {{ settings.inputs_radius }}px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 1em;
    cursor: pointer;
    transition: opacity 0.2s ease;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .add-to-cart-btn2 .cart-icon {
    display: flex;
    align-items: center;
  }

  .add-to-cart-btn2 .cart-icon svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .add-to-cart-btn2:hover {
    opacity: 0.9;
  }

  .popular-badge {
    position: absolute;
    top: -17px;
    right: -15px;
    background: #F01C7C;
    color: white;
    padding: 4px 8px;
    border-radius: 20px;
    font-size: 0.7em;
    font-weight: 500;
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
</style>

<script src="{{ 'buy-more-save-more.js' | asset_url }}" defer></script>