<!-- HLS.js para suporte universal a vídeos HLS -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest" defer></script>

<script>
window.athleteVideosModal = (function() {
  var overlay = document.getElementById('athlete-videos-modal-overlay');
  if (!overlay) {
    console.error('Modal overlay não encontrado');
    return function() {};
  }
  
  var player = overlay.querySelector('.athlete-videos-modal-player');
  var closeBtn = overlay.querySelector('.athlete-videos-modal-close');
  var prevBtn = overlay.querySelector('.athlete-videos-modal-prev');
  var nextBtn = overlay.querySelector('.athlete-videos-modal-next');
  var errorDiv = overlay.querySelector('.athlete-videos-modal-error');
  var retryBtn = overlay.querySelector('.athlete-videos-modal-retry');
  var muteBtn = overlay.querySelector('.athlete-videos-modal-mute-toggle');
  var iconMuted = muteBtn ? muteBtn.querySelector('.icon-muted') : null;
  var iconUnmuted = muteBtn ? muteBtn.querySelector('.icon-unmuted') : null;
  var videos = [];
  var current = 0;
  
  function openModal(videoList, idx) {
    if (!videoList || videoList.length === 0) {
      return;
    }
    
    // Filtrar vídeos vazios ou inválidos
    videos = videoList.filter(function(video) {
      return video && video.trim() !== '';
    });
    
    if (videos.length === 0) {
      return;
    }
    
    current = idx || 0;
    if (current >= videos.length) {
      current = 0;
    }
    
    showVideo(current);
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  
  function closeModal() {
    overlay.style.display = 'none';
    if (player) {
      player.pause();
      player.src = '';
    }
    document.body.style.overflow = '';
  }
  
  function showVideo(idx) {
    if (!videos[idx] || !player) {
      showError();
      return;
    }
    
    // Verificar se o URL está completo
    var videoUrl = videos[idx];
    if (videoUrl.startsWith('/') && !videoUrl.startsWith('//')) {
      videoUrl = window.location.origin + videoUrl;
    }
    
    // Verificar se é HLS (.m3u8) e se o browser suporta
    var isHLS = videoUrl.includes('.m3u8');
    
    // Esconder erro e mostrar player
    if (errorDiv) errorDiv.style.display = 'none';
    if (player) player.style.display = 'block';
    
    // Limpar o player primeiro
    player.pause();
    player.src = '';
    
    // Se for HLS e o browser não suportar nativamente, usar HLS.js
    if (isHLS && !player.canPlayType('application/vnd.apple.mpegurl') && window.Hls) {
      var hls = new window.Hls();
      hls.loadSource(videoUrl);
      hls.attachMedia(player);
      hls.on(window.Hls.Events.MANIFEST_PARSED, function() {
        player.muted = true;
        updateMuteIcon();
        var playPromise = player.play();
        if (playPromise !== undefined) {
          playPromise.catch(function(error) {
            // Silenciosamente ignora erros de autoplay
          });
        }
      });
      hls.on(window.Hls.Events.ERROR, function(event, data) {
        showError();
      });
    } else {
      // Método padrão para vídeos normais ou HLS nativo
      player.src = videoUrl;
      player.currentTime = 0;
      player.muted = true; // Força muted para autoplay funcionar
      updateMuteIcon();
      
      player.addEventListener('error', function(e) {
        showError();
      });
      
      setTimeout(function() { 
        var playPromise = player.play();
        if (playPromise !== undefined) {
          playPromise.catch(function(error) {
            // Silenciosamente ignora erros de autoplay
          });
        }
      }, 200);
    }
  }
  
  function showError() {
    if (player) player.style.display = 'none';
    if (errorDiv) errorDiv.style.display = 'flex';
  }
  
  function updateMuteIcon() {
    if (!muteBtn || !iconMuted || !iconUnmuted) return;
    if (player.muted) {
      iconMuted.style.display = 'flex';
      iconUnmuted.style.display = 'none';
    } else {
      iconMuted.style.display = 'none';
      iconUnmuted.style.display = 'flex';
    }
  }

  function toggleMute() {
    player.muted = !player.muted;
    updateMuteIcon();
  }
  
  function showPrev() {
    current = (current - 1 + videos.length) % videos.length;
    showVideo(current);
  }
  
  function showNext() {
    current = (current + 1) % videos.length;
    showVideo(current);
  }
  
  // Event listeners
  if (closeBtn) closeBtn.onclick = closeModal;
  if (prevBtn) prevBtn.onclick = showPrev;
  if (nextBtn) nextBtn.onclick = showNext;
  if (retryBtn) retryBtn.onclick = function() { showVideo(current); };
  if (muteBtn) muteBtn.onclick = toggleMute;
  
  if (overlay) {
    overlay.onclick = function(e) { 
      if (e.target === overlay) closeModal(); 
    };
  }
  
  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    if (overlay && overlay.style.display === 'flex') {
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') showPrev();
      if (e.key === 'ArrowRight') showNext();
      e.preventDefault();
    }
  });
  
  // Permite unmute ao clicar no vídeo
  if (player) {
    player.addEventListener('click', toggleMute);
  }
  
  return openModal;
})();
</script>

