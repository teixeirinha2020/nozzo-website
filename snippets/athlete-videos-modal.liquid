  <div class="athlete-videos-modal" style="position:relative; max-width:90vw; max-height:90vh; display:flex; align-items:center; justify-content:center;">
    <button class="athlete-videos-modal-close" aria-label="Fechar vídeo" style="position:absolute;top:-10px;right:-10px;width:40px;height:40px;font-size:1.5rem;background:rgba(0,0,0,0.8);border:none;border-radius:50%;color:#fff;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center;">&times;</button>
    <button class="athlete-videos-modal-prev" aria-label="Vídeo anterior" style="position:absolute;left:-25px;top:50%;transform:translateY(-50%);width:50px;height:50px;font-size:1.5rem;background:rgba(0,0,0,0.8);border:none;border-radius:50%;color:#fff;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center;">&#8592;</button>
