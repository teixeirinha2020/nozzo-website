<!-- Add to Cart Popup Snippet Rendered -->
{% assign current_variant = product.selected_or_first_available_variant %}
{% assign current_variant_id = current_variant.id %}
{% assign glass_blur_int = block.settings.glass_blur | default: 10 %}
{% assign compare_at_price_2 = current_variant.compare_at_price %}
{% assign  price_2 = current_variant.price %}

<div class="add-to-cart-popup{% if block.settings.enable_glass_effect %} glass-effect-popup{% endif %}" 
     data-variant-id="{{ current_variant_id }}" 
     data-product-id="{{ product.id }}"
     data-product-title="{{ product.title | escape }}">
  <div class="popup-content">
    <div class="product-info">
      <div class="product-image">
        <img src="{{ product.featured_image | img_url: '80x80', crop: 'center' }}" 
             alt="{{ product.featured_image.alt | escape }}"
             width="80" 
             height="80"
             loading="lazy"
             id="popup-product-image">
      </div>
      
      <div class="product-details">
        <h3 class="product-title" id="popup-product-title">{{ product.title }}</h3>
        <h3 class="product-title product-title-2" id="popup-product-title-2">{{ product.title }}</h3>
        <div class="product-price-2">
          <div class="price-container">
            <span class="current-price" id="popup-current-price2">€{{ price_2 | divided_by: 100.0 | round: 2 }}</span>
            <s class="compare-price" id="popup-compare-price2" style="display: none;">€{{ compare_at_price_2 | divided_by: 100.0 | round: 2 }}</s>
          </div>
          <div class="discount-badge-v2" id="popup-discount-badge" style="display:none; background: {{ block.settings.discount_badge_bg_color_popup }};"></div>
        </div>
      </div>
    </div>
    <div class="popup-actions-and-price">
      <div class="product-price">
          <div class="price-container">
            <span class="current-price" id="popup-current-price">€{{ current_variant.price | divided_by: 100.0 | round: 2 }}</span>
            <s class="compare-price" id="popup-compare-price" style="display: none;">€{{ current_variant.compare_at_price | divided_by: 100.0 | round: 2 }}</s>
          </div>
          <div class="discount-badge-v2" id="popup-discount-badge-2" style="display:none; background: {{ block.settings.discount_badge_bg_color_popup }};"></div>
        </div>
      <div class="popup-actions">
        <button type="button" class="add-to-cart-btn" style="background: {{ block.settings.button_bg_color }}; color: {{ block.settings.button_text_color }}">
          <span class="cart-icon">
            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" x="0" y="0" viewBox="0 0 128 128" style="enable-background:new 0 0 128 128" xml:space="preserve"><path fill="currentColor" d="M45.3 81.2h78V43.7L35.9 25.4l-3.1-12.9-12.6-4.2c0-.2.1-.3.1-.5 0-4.3-3.5-7.8-7.8-7.8S4.7 3.5 4.7 7.8s3.5 7.8 7.8 7.8c1.8 0 3.4-.6 4.7-1.6l9.4 4.7L39 78l-12.5 9.4V103l5.7 7.1c-1.6 1.9-2.5 4.3-2.5 7 0 6 4.9 10.9 10.9 10.9s10.9-4.9 10.9-10.9-4.9-10.9-10.9-10.9c-.9 0-1.8.1-2.6.3l-2.1-3.4h65.6l3.6 6c-2.2 2-3.6 4.9-3.6 8.1 0 6 4.9 10.9 10.9 10.9s10.9-4.9 10.9-10.9-4.9-10.9-10.9-10.9h-.3l-1.3-3.1h12.5V97H32.8v-6.2l12.5-9.6zm0-6.3-4.6-21.4.6 3L59.8 58l3.8 17H45.3zm21.8 0-3.7-16.7 18.1 1.4 1.4 15.3H67.1zm18.8 0-1.4-15 17 1.3v13.7H85.9zm31.2-15.6v15.6h-12.5V61.5l12.5 1v-3.2l-12.5-1V44.4l12.5 2.4v12.5zM35.9 31.2l65.6 12.6V58l-17.3-1.4-1.5-16.4-3.1-.6 1.6 16.8-18.5-1.5-4.3-19.3-3.7-.7 4.4 19.7-18.5-1.5-4.7-21.9zm76.5 81.2c2.6 0 4.7 2.1 4.7 4.7s-2.1 4.7-4.7 4.7-4.7-2.1-4.7-4.7 2.1-4.7 4.7-4.7zm-71.8 0c2.6 0 4.7 2.1 4.7 4.7s-2.1 4.7-4.7 4.7-4.7-2.1-4.7-4.7 2.1-4.7 4.7-4.7z"/></svg>
          </span>
          <span class="button-text" 
                data-onetime-text="{{ block.settings.button_text }}"
                data-subscription-text="{{ block.settings.subscription_button_text | default: 'Subscribe Now' }}">
            {{ block.settings.button_text }}
          </span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
.add-to-cart-popup {
  position: fixed;
  top: 20px;
  left: 0;
  right: 0;
  z-index: 7;
  margin: 0px 30px;
  background-color: rgb(var(--color-background));
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
  border-bottom: 1px solid rgb(var(--color-foreground-4));
  border-radius: .5rem;

  transform: translateY(-50px) scale(0.98);
  opacity: 0;
  visibility: hidden;
  transition: 
    transform 1s cubic-bezier(0.22, 1, 0.36, 1), 
    opacity 0.7s ease, 
    visibility 0.7s ease;
}

.add-to-cart-popup.show {
  transform: translateY(0) scale(1);
  opacity: 1;
  visibility: visible;
}

.add-to-cart-popup.with-header {
  top: calc(var(--header-bottom-position, 0px) + 10px);
}


  .popup-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 50px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .product-info {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
  }

  .popup-actions-and-price {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
  }

  .product-image {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-details {
    flex: 1;
  }

  .product-title {
    margin:0;
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.5px;
    color: rgb(var(--color-foreground));
    line-height: 1.2;
    width: fit-content;
  }

  .product-price {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
  }

  .product-price-2 {
    display: none;
    flex-direction: row;
    align-items: center;
    gap: 6px;
  }

  .product-title-2 {
    display: none;
  }

  .price-container {
    display: flex;
    flex-direction: row;
    gap: 6px;
    align-items: center;
  }

  .discount-badge-v2 {
    margin-left: 0;
  }

  .current-price {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.5px;
    line-height: 1;
    color: rgb(var(--color-foreground));
  }

  .compare-price {
    font-size: 18px;
    color: rgb(var(--color-foreground-4));
    letter-spacing: -0.5px;
    text-decoration: line-through;
    line-height: 1;
  }

  .popup-actions {
    flex-shrink: 0;
  }

  .add-to-cart-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border: none;
    border-radius: var(--inputs-radius);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: -0.5px;
    cursor: pointer;
    transition: opacity 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .add-to-cart-btn:hover {
    opacity: 0.9;
  }

  .add-to-cart-btn .cart-icon {
    display: flex;
    align-items: center;
  }

  .add-to-cart-btn .cart-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .discount-badge-v2 {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 400;
    background: {{ block.settings.discount_badge_bg_color | default: 'var(--color-accent, #F01C7C)' }};
    color: #fff;
  }

  @media screen and (max-width: 990px) {
    .popup-content {
      padding: 6px 32px;
    }

    .product-title , .current-price {
      font-size: 18px;
    }

    .compare-price {
      font-size: 16px ;
    }

    .price-container {
      flex-direction: column;
      align-items: center;
      gap: 2px;
    }

  }

  @media screen and (max-width: 749px) {
    .popup-content {
      padding: 6px 30px;
    }

    .product-info {
      justify-content: center;
    }

    .add-to-cart-popup .product-price {
      display: none;
    }

    .product-price-2 {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 6px;
    }

    .price-container {
      display: flex;
      flex-direction: row;
      gap: 6px;
    }

    .product-title {
      font-size: 16px;
    }

    .current-price {
      font-size: 16px;
    }

    .compare-price {
      font-size: 14px;
    }

    .add-to-cart-btn {
      width: 100%;
      justify-content: center;
      padding: 14px 20px;
    }

    .product-details {
      gap: 4px;
      display: flex;
      flex-direction: column;
    }
  }

  @media screen and (max-width: 630px) {
    .add-to-cart-popup .button-text {
      display: none;
    }
    
    .product-image {
      width: 50px;
      height: 50px;
    }
    
    .add-to-cart-btn {
      padding: 12px 20px;
      width: 120px;
    }

    .product-info {
      gap: 6px;
    }
  }

  @media screen and (max-width: 520px){

    .popup-content {
      padding: 6px 12px;
    }

    .product-details {
      gap: 2px;
    }

    .add-to-cart-btn {
      padding: 12px 16px;
      border-radius: 10px;
      width: fit-content;
    }

    .product-title {
      font-size: 14px;
    }

    .current-price {
      font-size: 14px;
    }

    .compare-price {
      font-size: 13px;
    }

    .product-price-2 , .price-container {
      gap: 3px;
    }
  }

  @media screen and (max-width: 365px) {

    .product-title {
      display: none;
    }

    .product-title-2 {
      display: flex;
    }
    
    .price-container {
      flex-direction: column;
      gap:0;
    }
    .product-price-2 {
      gap: 6px;
    }
  }

 .glass-effect-popup {
    background-color: transparent !important;
  }
  
 .glass-effect-popup:before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur({{ glass_blur_int }}px) saturate(180%);
    -webkit-backdrop-filter: blur({{ glass_blur_int }}px) saturate(180%); /* suporte para Safari */
    box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2), inset 0 4px 20px rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(210, 210, 210, 0.8);
    border-radius: 0.5rem;
  }

  .glass-effect-popup:after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.1);
    border-radius: .5rem;
    backdrop-filter: blur(1px);
    box-shadow: inset -10px -8px 0px -11px rgba(255, 255, 255, 1),
                inset 0px -9px 0px -8px rgba(255, 255, 255, 1);
    opacity: 0.6;
    z-index: -1;
    filter: blur(1px) drop-shadow(10px 4px 6px black) brightness(115%);
  }
</style>

<script>
class AddToCartPopup {
  constructor() {
    this.popup = document.querySelector('.add-to-cart-popup');
    this.mainProductSection = document.querySelector('.section-main-product') || 
                              document.querySelector('[data-section*="main-product"]') ||
                              document.querySelector('product-info') ||
                              document.querySelector('.product');
    this.header = document.querySelector('.section-header');
    this.isVisible = false;
    this.isHeaderVisible = false;
    this.lastScrollTop = 0;

    if (!this.popup || !this.mainProductSection) return;

    this.init();
  }

  init() {
    this.setupEventListeners();
    this.updateVariantId();
    this.updatePopupContent();
  }

  setupEventListeners() {
    window.addEventListener('scroll', this.handleScroll.bind(this), { passive: true });
    document.addEventListener('change', this.handleVariantChange.bind(this));
    document.addEventListener('variantChange', this.updateVariantId.bind(this));

    // Listen for quantity choice changes in buy-more-save-more
    document.addEventListener('change', this.handleQuantityChoiceChange.bind(this));

    // Listen for purchase type changes (one-time vs subscription)
    document.addEventListener('change', this.handlePurchaseTypeChange.bind(this));

    // Listen for subscription plan changes
    document.addEventListener('change', this.handleSubscriptionPlanChange.bind(this));

    // Listen for subscription quantity changes
    document.addEventListener('change', this.handleSubscriptionQuantityChange.bind(this));

    // Listen for window resize to update badge format
    window.addEventListener('resize', this.handleResize.bind(this), { passive: true });

    const addToCartBtn = this.popup.querySelector('.add-to-cart-btn');
    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', this.handleAddToCart.bind(this));
    }
  }

  handleQuantityChoiceChange(event) {
    if (event.target.matches('input[name="quantity-choice"]')) {
      this.updatePopupContent();
    }
  }

  handlePurchaseTypeChange(event) {
    if (event.target.matches('input[name="purchase-type"]')) {
      this.updatePopupContent();
    }
  }

  handleSubscriptionPlanChange(event) {
    if (event.target.matches('input[name="subscription-plan"]')) {
      this.updatePopupContent();
    }
  }

  handleSubscriptionQuantityChange(event) {
    if (event.target.matches('input[name="subscription-quantity"]')) {
      this.updatePopupContent();
    }
  }

  handleResize() {
    // Atualizar apenas a badge quando a tela for redimensionada
    const discountBadge = document.getElementById('popup-discount-badge');
    if (discountBadge && discountBadge.style.display !== 'none') {
      this.updateDiscountBadge();
    }
  }

  updateDiscountBadge() {
    const discountBadge = document.getElementById('popup-discount-badge');
    if (!discountBadge) return;

    const buyMoreSaveMore = document.querySelector('.buy-more-save-more');
    if (!buyMoreSaveMore) return;

    const selectedPurchaseType = document.querySelector('input[name="purchase-type"]:checked');
    const isSubscription = selectedPurchaseType && selectedPurchaseType.value.startsWith('subscription');

    let savingsText = '';

    if (isSubscription) {
      // For subscriptions, get the savings from subscription quantity options
      const selectedSubQuantity = document.querySelector('input[name="subscription-quantity"]:checked');
      if (selectedSubQuantity) {
        const quantityOption = selectedSubQuantity.closest('.subscription-quantity-option');
        if (quantityOption) {
          const savings = quantityOption.querySelector('.subscription-savings');
          if (savings && savings.textContent.match(/\d+%/)) {
            savingsText = savings.textContent.trim();
          }
        }
      }
    } else {
      // For one-time purchases, get the savings from quantity options
      const selectedOption = document.querySelector('input[name="quantity-choice"]:checked');
      if (selectedOption) {
        const optionContent = selectedOption.closest('.quantity-option');
        if (optionContent) {
          const savings = optionContent.querySelector('.savings p');
          if (savings && savings.textContent.match(/\d+%/)) {
            savingsText = savings.textContent.trim();
          }
        }
      }
    }

    if (savingsText) {
      const percentageMatch = savingsText.match(/(\d+)%/);
      if (percentageMatch) {
        const percentage = percentageMatch[1];
        
        if (window.innerWidth <= 365) {
          discountBadge.textContent = `-${percentage}%`;
        } else {
          discountBadge.textContent = savingsText;
        }
      }
      discountBadge.style.display = 'inline-flex';
    } else {
      discountBadge.style.display = 'none';
    }
  }

  updatePopupContent() {
    // Check if buy-more-save-more exists
    const buyMoreSaveMore = document.querySelector('.buy-more-save-more');
    if (!buyMoreSaveMore) return;

    // Check if we're in subscription mode
    const selectedPurchaseType = document.querySelector('input[name="purchase-type"]:checked');
    const isSubscription = selectedPurchaseType && selectedPurchaseType.value.startsWith('subscription');

    if (isSubscription) {
      this.updateSubscriptionContent();
    } else {
      this.updateOneTimeContent();
    }

    // Update button text based on purchase type
    this.updateButtonText(isSubscription);
  }

  updateOneTimeContent() {
    const selectedOption = document.querySelector('input[name="quantity-choice"]:checked');
    if (!selectedOption) return;

    const quantity = parseInt(selectedOption.value);
    const optionContent = selectedOption.closest('.quantity-option');
    
    if (!optionContent) return;

    // Update image
    const optionImage = document.getElementById(`option-${quantity}-image`);
    const popupImage = document.getElementById('popup-product-image');
    if (optionImage && popupImage) {
      popupImage.src = optionImage.src;
      popupImage.alt = optionImage.alt;
    } else {
      this.setFallbackImage();
    }

    // Update title
    const optionTitle = document.getElementById(`option-${quantity}-title`);
    const popupTitle = document.getElementById('popup-product-title');
    const popupTitle2 = document.getElementById('popup-product-title-2');
    if (optionTitle && popupTitle) {
      const productName = this.popup.dataset.productTitle || '{{ product.title }}';
      const optionTitleText = optionTitle.textContent;
      popupTitle.textContent = `${productName} ${optionTitleText}`;
      popupTitle2.textContent = `${optionTitleText}`;
    }

    // Update price
    const priceAmount = optionContent.querySelector('.price-amount');
    const originalPrice = optionContent.querySelector('.original-price');
    this.updatePriceDisplay(priceAmount, originalPrice);

    // Update discount badge
    this.updateDiscountBadge();
  }

  updateSubscriptionContent() {
    const selectedSubQuantity = document.querySelector('input[name="subscription-quantity"]:checked');
    if (!selectedSubQuantity) return;

    const quantity = parseInt(selectedSubQuantity.value);
    const quantityOption = selectedSubQuantity.closest('.subscription-quantity-option');
    
    if (!quantityOption) return;

    // Update image - try to find corresponding option image
    let optionImage = quantityOption.querySelector('.option-image img');
    if (!optionImage) {
      // Fallback to main option images
      optionImage = document.getElementById(`option-${quantity}-image`);
    }
    
    const popupImage = document.getElementById('popup-product-image');
    if (optionImage && popupImage) {
      popupImage.src = optionImage.src;
      popupImage.alt = optionImage.alt;
    } else {
      this.setFallbackImage();
    }

    // Update title
    const titleElement = quantityOption.querySelector('.title-and-badge h4');
    const popupTitle = document.getElementById('popup-product-title');
    const popupTitle2 = document.getElementById('popup-product-title-2');
    
    if (titleElement && popupTitle) {
      const productName = this.popup.dataset.productTitle || '{{ product.title }}';
      const optionTitleText = titleElement.textContent;
      
      // Get subscription plan name
      const selectedPlan = document.querySelector('input[name="subscription-plan"]:checked');
      const planName = selectedPlan ? selectedPlan.closest('.subscription-plan-option').querySelector('h4').textContent : '';
      
      popupTitle.textContent = `${productName} ${optionTitleText}`;
      popupTitle2.textContent = planName ? `${optionTitleText} (${planName})` : optionTitleText;
    }

    // Update price from subscription calculations
    const priceAmount = quantityOption.querySelector('.subscription-price-amount');
    const originalPrice = quantityOption.querySelector('.subscription-original-price');
    this.updatePriceDisplay(priceAmount, originalPrice);

    // Update discount badge
    this.updateDiscountBadge();
  }

  updatePriceDisplay(priceAmount, originalPrice) {
    const popupCurrentPrice = document.getElementById('popup-current-price');
    const popupComparePrice = document.getElementById('popup-compare-price');
    const popupCurrentPrice2 = document.getElementById('popup-current-price2');
    const popupComparePrice2 = document.getElementById('popup-compare-price2');

    if (priceAmount && popupCurrentPrice) {
      popupCurrentPrice.textContent = priceAmount.textContent;
      popupCurrentPrice2.textContent = priceAmount.textContent;
    }

    if (originalPrice && originalPrice.style.display !== 'none' && originalPrice.textContent.trim() && popupComparePrice) {
      popupComparePrice.textContent = originalPrice.textContent;
      popupComparePrice.style.display = 'inline';
      popupComparePrice2.textContent = originalPrice.textContent;
      popupComparePrice2.style.display = 'inline';
    } else if (popupComparePrice) {
      popupComparePrice.style.display = 'none';
      popupComparePrice2.style.display = 'none';
    }
  }

  updateButtonText(isSubscription) {
    const buttonText = this.popup.querySelector('.add-to-cart-btn .button-text');
    if (!buttonText) return;

    if (isSubscription) {
      // Try to get subscription button text from buy-more-save-more
      const bmsmButton = document.querySelector('.buy-more-save-more .add-to-cart-btn2 .button-text');
      const subscriptionText = bmsmButton ? bmsmButton.getAttribute('data-subscription-text') : null;
      buttonText.textContent = subscriptionText || '{{ block.settings.subscription_button_text }}' || 'Subscribe Now';
    } else {
      // Use one-time purchase text
      const bmsmButton = document.querySelector('.buy-more-save-more .add-to-cart-btn2 .button-text');
      const onetimeText = bmsmButton ? bmsmButton.getAttribute('data-onetime-text') : null;
      buttonText.textContent = onetimeText || '{{ block.settings.button_text }}' || 'Add to Cart';
    }
  }

  setFallbackImage() {
    const featuredImage = document.querySelector('.product__media img, .product__media-item img');
    const popupImage = document.getElementById('popup-product-image');
    if (featuredImage && popupImage) {
      popupImage.src = featuredImage.src;
      popupImage.alt = featuredImage.alt;
    }
  }

  handleScroll() {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    const mainProductRect = this.mainProductSection.getBoundingClientRect();
    const mainProductBottom = mainProductRect.bottom + scrollTop;

    const isPastMainProduct = scrollTop > mainProductBottom;

    // ✅ Updated logic for checking visible sticky header
    const isHeaderVisible = this.header &&
      this.header.classList.contains('shopify-section-header-sticky') &&
      this.header.classList.contains('animate') &&
      !this.header.classList.contains('shopify-section-header-hidden');

    if (isPastMainProduct) {
      if (!this.isVisible) {
        this.showPopup();
      }

      if (isHeaderVisible !== this.isHeaderVisible) {
        this.isHeaderVisible = isHeaderVisible;
        this.updatePopupPosition();
      }
    } else {
      if (this.isVisible) {
        this.hidePopup();
      }
    }

    this.lastScrollTop = scrollTop;
  }

  showPopup() {
    this.isVisible = true;
    this.popup.classList.add('show');
    this.updatePopupPosition();
    this.updatePopupContent(); // Update content when showing popup
  }

  hidePopup() {
    this.isVisible = false;
    this.isHeaderVisible = false;
    this.popup.classList.remove('show', 'with-header');
  }

  updatePopupPosition() {
    if (this.isHeaderVisible) {
      this.popup.classList.add('with-header');
    } else {
      this.popup.classList.remove('with-header');
    }
  }

  handleVariantChange(event) {
    if (event.target.matches('form[action*="/cart/add"] [name="id"]')) {
      this.updateVariantId();
    }
  }

  updateVariantId() {
    const variantIdField = document.querySelector('form[action*="/cart/add"] [name="id"]');
    if (variantIdField && this.popup) {
      this.popup.dataset.variantId = variantIdField.value;
    }
  }

  async handleAddToCart() {
    const variantId = parseInt(this.popup.dataset.variantId);
    const productId = parseInt(this.popup.dataset.productId);

    // Check if we're in subscription mode
    const selectedPurchaseType = document.querySelector('input[name="purchase-type"]:checked');
    const isSubscription = selectedPurchaseType && selectedPurchaseType.value.startsWith('subscription');

    let formData;

    if (isSubscription) {
      // Get subscription details
      const selectedPlan = document.querySelector('input[name="subscription-plan"]:checked');
      const selectedSubQuantity = document.querySelector('input[name="subscription-quantity"]:checked');
      
      if (!selectedPlan || !selectedSubQuantity) {
        console.error('Missing subscription selection');
        return;
      }

      const quantity = parseInt(selectedSubQuantity.value);
      const sellingPlan = selectedPlan.value;
      const groupId = selectedPurchaseType.value.replace('subscription-', '');
      const subscriptionDiscount = parseFloat(selectedSubQuantity.dataset.discount) || 0;

      formData = {
        items: [{
          id: variantId,
          quantity: quantity,
          selling_plan: sellingPlan,
          properties: {
            '_subscription': 'true',
            '_selling_plan_group': groupId,
            '_subscription_quantity': quantity,
            '_subscription_discount': subscriptionDiscount
          }
        }]
      };
    } else {
      // One-time purchase
      let quantity = 1;
      const buyMoreSaveMore = document.querySelector('.buy-more-save-more');
      if (buyMoreSaveMore) {
        const selectedOption = buyMoreSaveMore.querySelector('input[name="quantity-choice"]:checked');
        if (selectedOption) {
          quantity = parseInt(selectedOption.value);
        }
      }

      formData = {
        items: [{
          id: variantId,
          quantity: quantity,
          properties: { '_discount_quantity': quantity }
        }]
      };
    }

    try {
      const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (response.ok) {
        const cartData = await response.json();

        const sectionsToRender = [
          { id: 'cart-drawer', section: 'cart-drawer', selector: '.drawer__inner' },
          { id: 'cart-icon-bubble', section: 'cart-icon-bubble', selector: '.shopify-section' }
        ];

        const sectionsResponse = await fetch(`${window.location.pathname}?sections=${sectionsToRender.map(section => section.section).join(',')}`);
        const sectionsJson = await sectionsResponse.json();

        const cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer) {
          cartData.sections = sectionsJson;
          cartDrawer.classList.remove('is-empty');
          if (typeof cartDrawer.renderContents === 'function') {
            cartDrawer.renderContents(cartData);
          }
          cartDrawer.setAttribute('open', '');
          cartDrawer.classList.add('animate', 'active');
          document.body.classList.add('overflow-hidden');
        }

        const cartIconBubble = document.getElementById('cart-icon-bubble');
        if (cartIconBubble && sectionsJson['cart-icon-bubble']) {
          cartIconBubble.innerHTML = sectionsJson['cart-icon-bubble'];
        }

        // Trigger cart update events
        document.dispatchEvent(new CustomEvent('cart:updated', {
          detail: { cart: cartData }
        }));
      } else {
        const errorText = await response.text();
        console.error('Cart add failed:', errorText);
      }
    } catch (error) {
      console.error('Add to Cart Error:', error);
    }
  }
}

// Initialize popup when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => {
    new AddToCartPopup();
  }, 100);
});

setTimeout(() => {
  if (!document.querySelector('.add-to-cart-popup')) {
    new AddToCartPopup();
  }
}, 1000);
</script>