            "custom_liquid": "<div class=\"delivery-tracker\" style=\"display: block !important;\">\n  <h3 class=\"delivery-heading\">Entrega Estimada: 15 de Maio</h3>\n  \n  <div class=\"tracker-container\">\n    <div class=\"tracker-step\">\n      <div class=\"icon-container\">\n        <div class=\"icon\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" viewBox=\"0 0 100 100\" version=\"1.1\" x=\"0px\" y=\"0px\"><title>lock-check-2</title><desc>Created with Sketch Beta.</desc><g stroke=\"none\" stroke-width=\"1\" fill=\"none\" fill-rule=\"evenodd\" sketch:type=\"MSPage\"><g sketch:type=\"MSArtboardGroup\" fill=\"#000000\"><path d=\"M30,42 L21.9803572,42 C17.5704912,42 14,45.586665 14,50.0110405 L14,85.9889595 C14,90.4258294 17.5729276,94 21.9803572,94 L78.0196428,94 C82.4295088,94 86,90.413335 86,85.9889595 L86,50.0110405 C86,45.5741706 82.4270724,42 78.0196428,42 L70,42 L70,25 C70,14.5042825 61.4914975,6 50.9957277,6 L49.0042723,6 C38.5074446,6 30,14.5065898 30,25 L30,42 L30,42 L30,42 Z M38,42 L62,42 L62,25.9973518 C62,19.363876 56.627417,14 50,14 C43.3860685,14 38,19.3713974 38,25.9973518 L38,42 L38,42 L38,42 Z M39.5824667,63.1606146 L34,68.8303073 L45.9824667,81 L50.1693167,76.7477305 L66,60.6696927 L60.4175333,55 L45.9824667,69.6606146 L39.5824667,63.1606146 L39.5824667,63.1606146 Z\" sketch:type=\"MSShapeGroup\"></path></g></g></svg>\n        </div>\n      </div>\n      <div class=\"step-info\">\n        <p class=\"step-name\">Pedido Efetuado</p>\n        <p class=\"step-date\" id=\"order-date\">14 May</p>\n      </div>\n    </div>\n    \n    <div class=\"tracker-connector\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"#fff\" viewBox=\"0 0 512 512\" xml:space=\"preserve\"><path d=\"M491.318 235.318H20.682C9.26 235.318 0 244.578 0 256c0 11.423 9.26 20.682 20.682 20.682h470.636c11.423 0 20.682-9.259 20.682-20.682s-9.259-20.682-20.682-20.682\"/><path d=\"M505.942 241.375 329.454 64.887c-8.077-8.076-2