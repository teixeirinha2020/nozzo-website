        },
        "card_YkzaH4": {
          "type": "card",
          "settings": {
            "redirect_button_text": "Stickers",
            "image": "shopify://shop_images/extra_stickers_front_refills.jpg",
            "subheading_text": "Stickers Refills",
            "heading_text": "Resistente ao Suor. Amigo da Pele.",
            "paragraph_text": "Os nossos stickers foram pensados para manter tudo no lugar, noite após noite. A cola especial garante uma fixação segura, mesmo com suor ou oleosidade na pele — sem irritar nem causar desconforto. São testados dermatologicamente, resistentes, hipoalergénicos e não contêm látex. Tudo isto para garantir que o teu descanso vem com conforto e confiança.",
